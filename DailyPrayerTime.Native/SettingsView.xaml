                                <TextBlock Text="🕋 1. Core Prayer Calculations &amp; Timing Settings" FontWeight="Bold" FontSize="13" Foreground="#60a5fa" Margin="0,5,0,4"/>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Location Name &amp; GPS Coordinates:</Bold> Denotes your physical city and exact location (Latitude/Longitude). <Italic>Why it's needed:</Italic> Astronomical prayer times are calculated mathematically using sun altitude angles based on your coordinate position. <Italic>How it works:</Italic> Typing your city and clicking "Search" queries the LocationIQ API to fill in coordinates instantly.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Calculation Method:</Bold> Islamic astronomical bodies calculate twilight differently. <Italic>Options:</Italic> Muslim World League (MWL), ISNA, Egypt, Umm Al-Qura (Makkah), Karachi (Shafi/Hanafi), JAKIM, MoRA, Gulf, and Manual. Selecting "Manual" unlocks the <Bold>Fajr/Isha Angle</Bold> fields, allowing you to define precise twilight angles (e.g. 18° or 19.5°) matching your local scholars.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Madhab (Asr School):</Bold> Choose between <Bold>Standard (Shafi/Maliki/Hanbali)</Bold> and <Bold>Hanafi</Bold>. <Italic>Why it's needed:</Italic> In Shafi, Asr starts when an object's shadow equals its height plus shadow at noon. In Hanafi, it starts when the shadow reaches double the height, pushing Asr roughly 45–60 minutes later.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>High Latitude Rule:</Bold> Custom rules for regions far from the equator (above 48° North/South) where astronomical twilight never fully fades during midsummer, causing Fajr/Isha calculations to fail. Options adjust angles automatically to partition the night (e.g. Middle of Night, One-Seventh, Angle-Based).
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Hijri Adjustment:</Bold> A dropdown to offset the lunar Islamic calendar by <Bold>-2, -1, 0, +1, or +2 days</Bold> to match local physical crescent moon sightings.
                                    </TextBlock>
                                </BulletDecorator>

                                <!-- CATEGORY 2: SPIRITUAL TRACKER -->
                                <TextBlock Text="📊 2. Tracker, Deeds, &amp; Auto-Backups" FontWeight="Bold" FontSize="13" Foreground="#60a5fa" Margin="0,8,0,4"/>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Enable Spiritual Tracker:</Bold> Main toggle to activate your prayer progress logging tab. Tracking prayers helps keep you motivated and accountable.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Good Deeds Popup:</Bold> Automatically triggers a tiny checklist box (e.g. Dhikr, Charity, Qur'an reading) a custom number of minutes (offset) after your prayer is finished. It helps turn small spiritual habits into automatic daily routines.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Daily Spiritual Summary Popup:</Bold> Prompts you at a custom designated hour (e.g. 10:30 PM) showing a beautiful, glassmorphic summary of all prayers offered and deeds performed during the day before you go to bed.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Auto-Backups:</Bold> Scheduled intervals (Disabled, Daily, Weekly, Monthly) along with a folder browser. Periodically zips and archives all your spiritual logs, checklists, and counters securely on your PC, so you never lose your history.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Monthly Report Card:</Bold> Tap the <Bold>Card</Bold> button at the top of the Tracker to instantly generate a premium shareable image (1080×1920 portrait) summarising your prayer completion rate, total counts, per-prayer breakdown bars, and a QR code. Save the file to your device or share it directly.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Cloud Sync (Google Account):</Bold> Enable Cloud Sync and sign in with your Google account to securely push your tracker, tasbih, Ramadan, and cycle data to Firebase cloud storage. Your data is stored under your unique Google UID, completely private from other users. Tap <Bold>Sync</Bold> in the Tracker tab or <Bold>Sync Now</Bold> in Settings to upload. Sign out at any time to disconnect.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Global Leaderboard &amp; Hall of Fame:</Bold> After syncing, your monthly prayer statistics automatically appear on the shared Global Leaderboard in the Tracker tab. Rankings are sorted by completion rate and total prayers. The top three users earn medal icons (🥇🥈🥉). The <Bold>Hall of Fame</Bold> sub-tab permanently records the previous months' top three champions. Enable <Bold>Anonymous Mode</Bold> in Tracker settings if you prefer to appear as "Anonymous" on the board.
                                    </TextBlock>
                                </BulletDecorator>

                                <!-- CATEGORY 3: REMINDERS & AUDIO -->
                                <TextBlock Text="🔔 3. Audio, Alerts, &amp; Adhan Personalization" FontWeight="Bold" FontSize="13" Foreground="#60a5fa" Margin="0,8,0,4"/>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Independent Adhan Toggles &amp; Presets:</Bold> Toggle audio notifications for Fajr, Dhuhr, Asr, Maghrib, Isha, or Tahajjud individually. Select built-in recordings (Makkah, Madinah, Alafasy, Nasser Al-Qatami, Mohammad Al-Menshawy) or upload custom MP3/WAV tracks. Fajr has a separate track option to allow playing the specialized Adhan containing <Italic>"As-salatu khayrun minan-nawm"</Italic> (Prayer is better than sleep).
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Interactive Adhan Notification Window:</Bold> When enabled, a beautiful translucent alert pops up when prayer time enters, showcasing the current prayer, timing range, congregation time, and a helpful **Mute** button to stop the audio instantly without closing the notification itself.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Pre-Adhan Offset Reminders:</Bold> Alerts you a custom amount of minutes before (e.g. 10 or 15 mins prior) via a native Windows toast notification to help you step away from work, perform wudu, and prepare for prayer peacefully.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Congregation (Jamaat) Times &amp; established Reminders:</Bold> Save the congregation times of your local mosque. Toggling this displays a dynamic countdown alert prior to Jamaat start so you can make it to congregation on time.
                                    </TextBlock>
                                </BulletDecorator>

                                <!-- CATEGORY 4: THEME & WINDOWS -->
                                <TextBlock Text="🎨 4. Layout, Themes, Interface &amp; Customization" FontWeight="Bold" FontSize="13" Foreground="#60a5fa" Margin="0,8,0,4"/>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Floating Overlay Widget:</Bold> Displays a translucent glassmorphic widget showing the current prayer name and a live countdown timer. Double-click to toggle, click and drag to place anywhere on your screen. Widget coordinate positions are saved automatically across restarts.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Taskbar Timer &amp; Styles:</Bold> Embeds a live countdown timer directly on your Windows taskbar. Choose between <Bold>Enhanced</Bold> (floating borderless text positioned right next to your tray area), <Bold>Integrated</Bold> (blends right into the center taskbar layout of Windows 11), or legacy <Bold>DeskBand</Bold>. You can choose 4 alignment offsets (Left of Tray, Right of Tray, Center, Left Near Start).
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Startup Options:</Bold> Toggle <Bold>Run on Windows Startup</Bold> to launch the app automatically. Enable <Bold>Run Silently on Startup</Bold> to start the app directly minimized to the system tray (keeping your screen clutter-free).
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>Interface Language &amp; Font Size Scaling:</Bold> Select one of 8 global interface languages. Scale the entire application interface smoothly using the <Bold>A−</Bold>, <Bold>A○ (Reset)</Bold>, and <Bold>A+</Bold> buttons.
                                    </TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="•" Foreground="#10b981" FontSize="12"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0">
                                        <Bold>HEX Colors &amp; Gradients:</Bold> Inputs for Gradient Start/End, Primary Accent, and Secondary Accent. Click the native <Bold>Pick</Bold> button to open a system color dialog to choose colors visually. Click "Reset to Default Colors" to instantly reload the premium dark green theme.
                                    </TextBlock>
                                </BulletDecorator>
                            </StackPanel>
                        </Border>

                        <!-- LATEST NEW UPDATES (CHANGELOG SUMMARY) -->
                        <Border Style="{StaticResource PremiumCardStyle}">
                            <StackPanel>
                                <TextBlock Text="✨ What's New in Version 2.5.1" FontWeight="Bold" FontSize="15" Foreground="#fbbf24" Margin="0,0,0,6"/>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="✅" FontSize="11"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0"><Bold>In-App Support Contact Form:</Bold> Send suggestions or bug reports to the developer directly from the Settings Support tab (requires cloud sign-in for secure messaging).</TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="✅" FontSize="11"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0"><Bold>Global Leaderboard &amp; Hall of Fame:</Bold> All signed-in users now compete on a shared Monthly Leaderboard inside the Tracker tab, sorted by completion rate. Medal icons crown the top three. A permanent Hall of Fame preserves each month's champions forever.</TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="✅" FontSize="11"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0"><Bold>Google Sign-In via In-App Browser:</Bold> Signing in with Google now opens a secure in-app window powered by WebView2 — no external browser tab is ever opened. The sign-in flow completes automatically and closes itself.</TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="✅" FontSize="11"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0"><Bold>Monthly Report Card:</Bold> Tap the Card button in the Tracker header to generate a beautiful 1080×1920 portrait image of your monthly prayer stats — complete with a QR code — ready to save or share.</TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="✅" FontSize="11"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0"><Bold>Cloud Sync Error Visibility:</Bold> Sync failures are now shown as clear error popups instead of silent no-ops. All cloud errors are also written to the built-in app_log.txt diagnostic log for easy troubleshooting.</TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,2,0,2">
                                    <BulletDecorator.Bullet><TextBlock Text="✅" FontSize="11"/></BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="10,0,0,0"><Bold>Premium Button Styles:</Bold> The Sync and Card buttons in the Tracker now feature a glassmorphic dark-glass look with hover/press glow effects matching the rest of the app's premium aesthetic.</TextBlock>
                                </BulletDecorator>
                            </StackPanel>
                        </Border>

                        <!-- SYSTEM DIAGNOSTIC LOGS CARD -->
                        <Border Style="{StaticResource PremiumCardStyle}">
                            <StackPanel>
                                <TextBlock Text="🛠️ System Diagnostic Logs" FontWeight="Bold" FontSize="15" Foreground="#f87171" Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="White" Opacity="0.8" Margin="0,0,0,8">
                                    If you encounter any issues, you can review the internal application logs below. Select the log type, read or copy the logs to share them directly with the developer:
                                </TextBlock>
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="LogTypeCombo" SelectionChanged="LogTypeCombo_SelectionChanged" Background="#20FFFFFF" Foreground="Black" BorderBrush="#40FFFFFF" Padding="5">
                                        <ComboBoxItem Content="Application Events (app_log.txt)" Tag="app_log.txt" IsSelected="True"/>
                                        <ComboBoxItem Content="Audio Notification Logs (audio_log.txt)" Tag="audio_log.txt"/>
                                    </ComboBox>
                                    <Button Grid.Column="1" Content="🔄 Refresh" Click="RefreshLogs_Click" Margin="8,0,0,0" Padding="12,5" Background="#20FFFFFF" Foreground="White" BorderBrush="#40FFFFFF" Cursor="Hand"/>
                                    <Button Grid.Column="2" Content="📋 Copy Logs" Click="CopyLogs_Click" Margin="8,0,0,0" Padding="12,5" Background="#10b981" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>

                                <Border Background="#30000000" CornerRadius="8" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="8">
                                    <TextBox x:Name="LogViewerBox" Height="150" Background="Transparent" Foreground="#9ca3af" BorderThickness="0" TextWrapping="Wrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto" FontSize="10.5" FontFamily="Consolas, Courier New"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
