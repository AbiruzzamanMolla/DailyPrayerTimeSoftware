<Window x:Class="DailyPrayerTime.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Daily Prayer Timer" 
        Height="600" 
        Width="450" 
        MinWidth="460" 
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/icon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      CornerRadius="0" 
                      GlassFrameThickness="0" 
                      UseAeroCaptionButtons="False" 
                      NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Gradients and Styles matching the React App -->
        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#d7bedc" Offset="0"/>
            <GradientStop Color="#ecdfee" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>
    
    <Border Background="#065F46" CornerRadius="15" BorderBrush="#20FFFFFF" BorderThickness="1">
        <Grid x:Name="MainGrid" Background="{StaticResource MainGradient}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> <!-- Custom Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Update Banner -->
                <RowDefinition x:Name="HeroRow" Height="Auto"/> <!-- Hero Section -->
                <RowDefinition x:Name="ListRow" Height="*"/>    <!-- Prayer List -->
                <RowDefinition x:Name="FooterRow" Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#111827">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Support -->
                    <ColumnDefinition Width="*"/>    <!-- Name (Center) -->
                    <ColumnDefinition Width="Auto"/> <!-- Controls -->
                </Grid.ColumnDefinitions>

                <!-- Left: Support Us Button -->
                <Button x:Name="SupportBtn" Click="Support_Click" Cursor="Hand" Margin="10,0,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#20FFFFFF"/>
                            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Height" Value="24"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="12">
                                            <StackPanel Orientation="Horizontal" Margin="10,0" VerticalAlignment="Center">
                                                <TextBlock Text="❤" Foreground="#F43F5E" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="Support Us" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#40FFFFFF"/>
                                    <Setter Property="BorderBrush" Value="#60FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Center: App Name Branding -->
                <TextBlock Text="DAILY PRAYER TIMER" 
                           Grid.Column="1"
                           Foreground="White" 
                           FontSize="10" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center" 
                           Opacity="0.6"
                           IsHitTestVisible="False"/>

                <!-- Right: Window Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,5,0" WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Ramadan Mode Toggle -->
                    <Button Click="RamadanMode_Click" Background="Transparent" BorderBrush="Transparent" Foreground="White" Width="30" Height="30" Cursor="Hand" ToolTip="Toggle Ramadan View">
                        <TextBlock x:Name="RamadanIcon" Text="🌙" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.7"/>
                    </Button>

                    <!-- Full Screen Toggle -->
                    <Button Click="FullScreen_Click" Background="Transparent" BorderBrush="Transparent" Foreground="White" Width="30" Height="30" Cursor="Hand" ToolTip="Toggle Full Screen Mode">
                        <TextBlock x:Name="FullScreenIcon" Text="⛶" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.7"/>
                    </Button>

                    <!-- Zen Mode Toggle -->
                    <Button Click="ZenMode_Click" Background="Transparent" BorderBrush="Transparent" Foreground="White" Width="30" Height="30" Cursor="Hand" ToolTip="Toggle Zen Mode">
                        <TextBlock x:Name="ZenModeIcon" Text="✨" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Settings (Relocated here for easy access) -->
                    <Button Click="Settings_Click" Background="Transparent" BorderBrush="Transparent" Foreground="White" Width="30" Height="30" Cursor="Hand">
                        <TextBlock Text="⚙" FontSize="16" />
                    </Button>
                    
                    <!-- Minimize -->
                    <Button Click="Minimize_Click" Background="Transparent" BorderBrush="Transparent" Foreground="White" Width="30" Height="30">
                        <TextBlock Text="─" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    
                    <!-- Maximize/Restore -->
                    <Button x:Name="MaximizeBtn" Click="Maximize_Click" Background="Transparent" BorderBrush="Transparent" Foreground="White" Width="30" Height="30">
                        <TextBlock x:Name="MaximizeIcon" Text="▢" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    
                    <!-- Close -->
                    <Button Click="Close_Click" Background="Transparent" BorderBrush="Transparent" Foreground="#EF4444" Width="30" Height="30">
                        <TextBlock Text="✕" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

        <!-- Update Notification (Hidden by default) -->
        <Border x:Name="UpdateBanner" Grid.Row="1" Margin="15,10,15,10" CornerRadius="8" Background="#fbbf24" Padding="12,8" Visibility="Collapsed" Cursor="Hand" MouseLeftButtonUp="UpdateBanner_Click">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="✨" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="UpdateTitleText" Text="Update Available!" Foreground="#170939" FontWeight="Bold" FontSize="14" />
                    <TextBlock x:Name="UpdateVersionText" Text="New version is ready." Foreground="#170939" FontSize="11" Opacity="0.8" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="Download →" Foreground="#170939" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border x:Name="HeroBorder" Grid.Row="2" Margin="15,12,15,12" CornerRadius="16" Background="#170939" ClipToBounds="True" VerticalAlignment="Top">
            <Grid>
                <!-- Dynamic Background XAML Vector -->
                <Viewbox x:Name="HeroBackgroundViewbox" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-20,0" Width="140" Height="140" Stretch="Uniform" Opacity="0.05">
                    <Path x:Name="HeroBackgroundPath" Fill="White" Data="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1z" />
                </Viewbox>
                
                <StackPanel Margin="20,15">
                    <!-- Location Name -->
                    <Viewbox MaxHeight="30" HorizontalAlignment="Center">
                        <TextBlock x:Name="HeroLocationText" Text="Loading..." Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </Viewbox>
                    
                    <!-- Time Until Label -->
                    <TextBlock x:Name="HeroTimeUntilLabel" Text="Calculating..." HorizontalAlignment="Center" Foreground="White" Opacity="0.8" FontSize="11" Margin="0,4,0,0"/>
                    
                    <!-- Countdown Display -->
                    <Viewbox MaxHeight="60" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <TextBlock x:Name="HeroCountdownText" Text="00:00:00" Foreground="White" FontSize="42" FontWeight="Bold"/>
                    </Viewbox>

                    <!-- Context and Nafal Notices -->
                    <TextBlock x:Name="HeroContextNoteText" Text="" HorizontalAlignment="Center" Foreground="#FBBF24" FontSize="11" Margin="0,2,0,0" Visibility="Collapsed"/>
                    <StackPanel x:Name="TahajjudHeroDisplay" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0" Visibility="Collapsed">
                        <TextBlock Text="Tahajjud ends in: " Foreground="White" Opacity="0.8" FontSize="11"/>
                        <TextBlock x:Name="TahajjudHeroTimerText" Text="00:00:00" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <Border x:Name="NafalNoticeHero" Background="#1AFFFFFF" CornerRadius="8" Padding="10,5" Margin="0,5,0,0" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="NafalNoticeText" Text="" Foreground="White" FontSize="11"/>
                    </Border>

                    <!-- Progress Row -->
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Previous Prayer -->
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="HeroPrevPrayerName" Text="Isha" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                            <TextBlock x:Name="HeroPrevPrayerTime" Text="7:34" Foreground="White" Opacity="0.7" FontSize="10"/>
                        </StackPanel>

                        <!-- Progress Bar (Sleeker) -->
                        <ProgressBar x:Name="HeroProgressBar" Grid.Column="1" Height="5" Value="50" Margin="12,0" VerticalAlignment="Center" Background="#1AFFFFFF" Foreground="White" BorderThickness="0"/>

                        <!-- Next Prayer -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock x:Name="HeroNextPrayerName" Text="Fajr" Foreground="White" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="HeroNextPrayerTime" Text="4:23" Foreground="White" Opacity="0.7" FontSize="10" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <!-- Rakat Note for Current Prayer -->
                    <TextBlock x:Name="HeroPrayerNote" Text="2 Sunnah (Mu'akkadah), 2 Fard (4 Total)" Foreground="White" Opacity="0.7" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,-8" TextWrapping="Wrap" MaxWidth="300" FontWeight="SemiBold"/>

                    <!-- Info Sub-Card -->
                    <Border Margin="0,15,0,0" Background="#14FFFFFF" CornerRadius="12" Padding="12,12">
                        <StackPanel>
                             <!-- Date Row -->
                            <Grid Margin="0,0,0,12">
                                <TextBlock x:Name="HeroSubDate" Text="10 April 2026" Foreground="White" Opacity="0.9" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HeroSubDay" Text="Friday" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HeroSubHijri" Text="25 Shawwal 1447" Foreground="White" Opacity="0.9" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            
                            <!-- Ramadan Specific View (Hidden by default) -->
                            <Grid x:Name="HeroRamadanGrid" Visibility="Collapsed" Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Suhur Ends" Foreground="White" Opacity="0.7" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="HeroSuhurTime" Text="--:--" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        <TextBlock x:Name="HeroSuhurStatus" Text="--:--:--" Foreground="White" Opacity="0.8" FontSize="9" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#1AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="5,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Iftar Begins" Foreground="White" Opacity="0.7" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="HeroIftarTime" Text="--:--" Foreground="#f87171" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        <TextBlock x:Name="HeroIftarStatus" Text="--:--:--" Foreground="White" Opacity="0.8" FontSize="9" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Default Prayer List Grid -->
                            <Grid x:Name="HeroDefaultGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Fajr -->
                                <Border Grid.Row="0" Grid.Column="0" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock Text="Fajr" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubFajrTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Sunrise (Sunrise label) -->
                                <Border Grid.Row="0" Grid.Column="1" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock x:Name="SunriseLabel" Text="Sunrise" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubShuruqTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Dhuhr Slot (Dynamic) -->
                                <Border Grid.Row="0" Grid.Column="2" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock x:Name="DhuhrLabel" Text="Dhuhr" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubDhuhrTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Asr -->
                                <Border Grid.Row="1" Grid.Column="0" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock x:Name="AsrLabel" Text="Asr" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubAsrTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Maghrib -->
                                <Border Grid.Row="1" Grid.Column="1" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock x:Name="MaghribLabel" Text="Maghrib" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubMaghribTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Isha / Tahajjud -->
                                <Border Grid.Row="1" Grid.Column="2" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock x:Name="IshaLabel" Text="Isha" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubIshaTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Prohibited Times Warning (Inside Card) -->
                    <Border x:Name="ProhibitedWarning" Background="#4dff0000" CornerRadius="6" Padding="8,4" Margin="0,10,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="ProhibitedText" Text="⚠️ Prohibited Prayer Time" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Prayer List -->
        <ScrollViewer x:Name="PrayerListScroll" Grid.Row="3" VerticalScrollBarVisibility="Hidden" Margin="15,0,15,15">
            <StackPanel>
                <!-- Daily Highlights: Suhur & Iftar -->
                <TextBlock Text="Daily Highlights" FontWeight="Bold" FontSize="13" Margin="0,6,0,4" Foreground="White" Opacity="0.8"/>
                <UniformGrid Columns="2" Margin="0,0,0,6">
                    <Border x:Name="SuhurCard" Background="#1AFFFFFF" CornerRadius="6" Padding="8" Margin="0,0,5,0">
                        <StackPanel>
                            <TextBlock x:Name="SuhurDateText" Text="Today, Apr 7" FontSize="9" Foreground="White" Opacity="0.6" Margin="0,0,0,2"/>
                            <TextBlock x:Name="SuhurNameText" Text="Suhur (Ends)" FontSize="10" FontWeight="SemiBold" Foreground="White" Opacity="0.7"/>
                            <TextBlock x:Name="SuhurTimeText" Text="--:-- AM" FontSize="14" FontWeight="Bold" Foreground="#60a5fa"/>
                            <TextBlock x:Name="SuhurCountdownText" Text="--:--:--" FontSize="10" Foreground="White" Opacity="0.8" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="IftarCard" Background="#1AFFFFFF" CornerRadius="6" Padding="8">
                        <StackPanel>
                            <TextBlock x:Name="IftarDateText" Text="Today, Apr 7" FontSize="9" Foreground="White" Opacity="0.6" Margin="0,0,0,2"/>
                            <TextBlock x:Name="IftarNameText" Text="Iftar (Begins)" FontSize="10" FontWeight="SemiBold" Foreground="White" Opacity="0.7"/>
                            <TextBlock x:Name="IftarTimeText" Text="--:-- PM" FontSize="14" FontWeight="Bold" Foreground="#f87171"/>
                            <TextBlock x:Name="IftarCountdownText" Text="--:--:--" FontSize="10" Foreground="White" Opacity="0.8" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
                
                <!-- Fasting Highlights Note (Restructured to prevent overlap) -->
                <Border x:Name="FastingNoteBorder" Background="#33FFFFFF" BorderBrush="#4DFFFFFF" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,10" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header Row -->
                        <Grid Grid.Row="0">
                            <TextBlock x:Name="FastingNoteText" Text="Sunnah Fasting Today" Foreground="White" FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,40,0"/>
                            <Button x:Name="FastingNoteToggleBtn" Click="FastingNote_Toggle_Click" Background="Transparent" BorderBrush="Transparent" Foreground="White" Padding="5,0" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="FastingNoteToggleIcon" Text="▼" FontSize="10" Opacity="0.7"/>
                            </Button>
                        </Grid>
                        
                        <!-- Collapsable Content for Friday (Row 1 ensures overlap prevention) -->
                        <StackPanel x:Name="FastingNoteExtraContent" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="FastingNoteDetailsText" Foreground="White" Opacity="0.9" FontSize="10.5" TextWrapping="Wrap" LineHeight="16"/>
                        </StackPanel>
                    </Grid>
                </Border>


                <!-- Prayer List with Ranges -->
                <TextBlock Text="Today's Prayer Times" FontWeight="Bold" FontSize="13" Margin="0,6,0,4" Foreground="White" Opacity="0.8"/>
                <Border x:Name="FajrCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock x:Name="FajrNameText" Text="Fajr" FontSize="15" FontWeight="Medium" Foreground="White"/>
                            <TextBlock x:Name="FajrRakatNote" Text="Total: 4 Rakats" FontSize="10" Foreground="#9ca3af" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="FajrTimeText" Text="--:-- AM - --:-- AM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="SunriseCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <TextBlock x:Name="SunriseNameText" Text="Sunrise" FontSize="15" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="SunriseTimeText" Text="--:-- AM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="DhuhrCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock x:Name="DhuhrNameText" Text="Dhuhr" FontSize="15" FontWeight="Medium" Foreground="White"/>
                            <TextBlock x:Name="DhuhrRakatNote" Text="Total: 12 Rakats" FontSize="10" Foreground="#9ca3af" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="DhuhrTimeText" Text="--:-- PM - --:-- PM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <!-- Jumu'ah (Friday) - Collapsed by default -->
                <Border x:Name="JumuahCard" Background="#1d4ed8" CornerRadius="6" Padding="12" Margin="0,0,0,6" Visibility="Collapsed">
                    <Grid>
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock x:Name="JumuahNameText" Text="Jumu'ah (Friday)" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="JumuahRakatNote" Text="Total: 14 Rakats" FontSize="10" Foreground="#bfdbfe" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="JumuahTimeText" Text="--:-- PM" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border x:Name="AsrCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock x:Name="AsrNameText" Text="Asr" FontSize="15" FontWeight="Medium" Foreground="White"/>
                            <TextBlock x:Name="AsrRakatNote" Text="Total: 8 Rakats" FontSize="10" Foreground="#9ca3af" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="AsrTimeText" Text="--:-- PM - --:-- PM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border x:Name="MaghribCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock x:Name="MaghribNameText" Text="Maghrib" FontSize="15" FontWeight="Medium" Foreground="White"/>
                            <TextBlock x:Name="MaghribRakatNote" Text="Total: 7 Rakats" FontSize="10" Foreground="#9ca3af" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="MaghribTimeText" Text="--:-- PM - --:-- PM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Border x:Name="IshaCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock x:Name="IshaNameText" Text="Isha" FontSize="15" FontWeight="Medium" Foreground="White"/>
                            <TextBlock x:Name="IshaRakatNote" Text="Total: 17 Rakats" FontSize="10" Foreground="#9ca3af" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="IshaTimeText" Text="--:-- PM - --:-- AM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <!-- Nafal Prayers -->
                <TextBlock Text="Nafal Prayers" FontWeight="Bold" FontSize="13" Margin="0,10,0,4" Foreground="White" Opacity="0.8"/>
                <StackPanel Margin="0,0,0,5">
                    <!-- Duha (Ishraq) -->
                    <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10" Margin="0,0,0,4">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Salat al-Duha (Ishraq)" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="DuhaRakatNote" Text="Min 2, up to 12 Rakats (Nafl)" FontSize="9" Foreground="#9ca3af" Margin="0,1,0,0" TextWrapping="Wrap" MaxWidth="180"/>
                            </StackPanel>
                            <TextBlock x:Name="DuhaTimeText" Text="--:-- AM - --:-- PM" FontSize="11" FontWeight="Bold" Foreground="#60a5fa" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    <!-- Awwabin -->
                    <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10" Margin="0,0,0,4">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Awwabin" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="AwwabinRakatNote" Text="Min 2, typically 6 Rakats (Nafl)" FontSize="9" Foreground="#9ca3af" Margin="0,1,0,0" TextWrapping="Wrap" MaxWidth="180"/>
                            </StackPanel>
                            <TextBlock x:Name="AwwabinTimeText" Text="--:-- PM - --:-- PM" FontSize="11" FontWeight="Bold" Foreground="#60a5fa" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    <!-- Tahajjud -->
                    <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10" Margin="0,0,0,4">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Tahajjud" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="TahajjudRakatNote" Text="Min 2, typically 8 Rakats (Nafl)" FontSize="9" Foreground="#9ca3af" Margin="0,1,0,0" TextWrapping="Wrap" MaxWidth="180"/>
                                <TextBlock x:Name="NightThirdNote" Text="Highest reward in Last 1/3" FontSize="8" Foreground="#fcd34d" Margin="0,1,0,0" TextWrapping="Wrap" MaxWidth="180"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="TahajjudTimeText" Text="--:-- PM - --:-- AM" FontSize="11" FontWeight="Bold" Foreground="#60a5fa" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="LastThirdTimeText" Text="Last 1/3: --:-- AM" FontSize="9" FontWeight="SemiBold" Foreground="#fcd34d" HorizontalAlignment="Right" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Prohibited Times (Relocated) -->
                <TextBlock Text="Prohibited Times" FontWeight="Bold" FontSize="13" Margin="0,10,0,4" Foreground="White" Opacity="0.8"/>
                <UniformGrid Columns="3" Margin="0,0,0,8">
                    <Border x:Name="SunriseProhibCard" Background="#4dff0000" CornerRadius="8" Padding="8" Margin="0,0,3,0">
                        <StackPanel>
                            <TextBlock Text="Sunrise" FontSize="11" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="SunriseProhibTimer" Text="--:--:--" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="SunriseProhibRange" Text="--:-- AM" FontSize="9" Foreground="White" Opacity="0.8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ZawalProhibCard" Background="#4dff0000" CornerRadius="8" Padding="8" Margin="0,0,3,0">
                        <StackPanel>
                            <TextBlock Text="Zawal" FontSize="11" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ZawalProhibTimer" Text="--:--:--" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ZawalProhibRange" Text="--:-- AM" FontSize="9" Foreground="White" Opacity="0.8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SunsetProhibCard" Background="#4dff0000" CornerRadius="8" Padding="8">
                        <StackPanel>
                            <TextBlock Text="Sunset" FontSize="11" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="SunsetProhibTimer" Text="--:--:--" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="SunsetProhibRange" Text="--:-- PM" FontSize="9" Foreground="White" Opacity="0.8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <!-- Sticky Prohibited Times (Enhanced for Readability) -->
        <Border x:Name="StickyFooter" Grid.Row="4" Background="#170939" BorderBrush="#1AFFFFFF" BorderThickness="0,1,0,0" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Sunrise -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Sunrise (Tulu)" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="StickySunriseProhibited" Text="--:-- - --:--" Foreground="White" FontSize="10" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                    <TextBlock x:Name="StickySunriseStatus" Text="Passed" Foreground="White" Opacity="0.7" FontSize="8" FontWeight="Medium" HorizontalAlignment="Center"/>
                </StackPanel>
&#160;
                <!-- Noon (With Separators) -->
                <Border Grid.Column="1" BorderBrush="#33FFFFFF" BorderThickness="1,0,1,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Noon (Zawal)" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="StickyZawalProhibited" Text="--:-- - --:--" Foreground="White" FontSize="10" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                        <TextBlock x:Name="StickyZawalStatus" Text="Upcoming" Foreground="White" Opacity="0.7" FontSize="8" FontWeight="Medium" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Sunset -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Sunset (Ghurub)" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="StickySunsetProhibited" Text="--:-- - --:--" Foreground="White" FontSize="10" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                    <TextBlock x:Name="StickySunsetStatus" Text="Upcoming" Foreground="White" Opacity="0.7" FontSize="8" FontWeight="Medium" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Border>
</Window>
