                            <TextBlock x:Name="SuhurNameText" Text="{DynamicResource Label_SuhurEndsShort}" FontSize="10" FontWeight="SemiBold" Foreground="White" Opacity="0.7"/>
                            <TextBlock x:Name="SuhurTimeText" Text="--:-- AM" FontSize="14" FontWeight="Bold" Foreground="#60a5fa"/>
                            <TextBlock x:Name="SuhurCountdownText" Text="--:--:--" FontSize="10" Foreground="White" Opacity="0.8" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="IftarCard" Background="#1AFFFFFF" CornerRadius="6" Padding="8" Margin="0,0,5,0">
