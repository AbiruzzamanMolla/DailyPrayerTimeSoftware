                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="TabPrayers" Style="{StaticResource BottomTabStyle}" Checked="TabPrayers_Checked" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6">
                        <TextBlock Text="🕒" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                        <TextBlock Text="{DynamicResource Tab_Salat}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
