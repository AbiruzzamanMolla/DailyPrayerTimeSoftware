                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="FajrTimeText" Text="--:-- AM - --:-- AM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="FajrJamatText" Text="Jamat: --:-- AM" FontSize="11" FontWeight="SemiBold" Foreground="#fbbf24" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border x:Name="SunriseCard" Style="{StaticResource PremiumCardStyle}" Visibility="Collapsed">
