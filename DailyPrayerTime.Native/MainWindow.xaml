<Window x:Class="DailyPrayerTime.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Daily Prayer Timer" 
        Width="350" 
        Height="670"
        Icon="pack://application:,,,/icon.ico"
        MinHeight="600" 
        MinWidth="320"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#170939">
    <Window.Resources>
        <!-- Gradients and Styles matching the React App -->
        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#d7bedc" Offset="0"/>
            <GradientStop Color="#ecdfee" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>
    
    <Grid Background="{StaticResource MainGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Update Banner -->
            <RowDefinition Height="Auto"/> <!-- Hero Section -->
            <RowDefinition Height="*"/>    <!-- Prayer List -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>
        
        <!-- Header: Location and Settings -->
        <Grid Grid.Row="0" Margin="15,15,15,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="LocationDisplay" Text="📍 Dhaka, Bangladesh" Foreground="#170939" FontWeight="Bold" FontSize="16" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock x:Name="EnglishDateDisplay" Text="Tuesday, Apr 7" Foreground="#170939" Opacity="0.8" FontSize="11" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBlock x:Name="HijriDateDisplay" Text="18 Ramadan 1447" Foreground="#170939" Opacity="0.6" FontSize="11"/>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Content="⚙" Click="Settings_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderBrush="Transparent" Foreground="#170939" FontSize="20" Cursor="Hand" />
        </Grid>

        <!-- Update Notification (Hidden by default) -->
        <Border x:Name="UpdateBanner" Grid.Row="1" Margin="15,0,15,10" CornerRadius="8" Background="#fbbf24" Padding="12,8" Visibility="Collapsed" Cursor="Hand" MouseLeftButtonUp="UpdateBanner_Click">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="✨" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="UpdateTitleText" Text="Update Available!" Foreground="#170939" FontWeight="Bold" FontSize="14" />
                    <TextBlock x:Name="UpdateVersionText" Text="New version is ready." Foreground="#170939" FontSize="11" Opacity="0.8" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="Download →" Foreground="#170939" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border x:Name="HeroBorder" Grid.Row="2" Margin="15,0,15,8" CornerRadius="12" Background="#170939" ClipToBounds="True">
            <Grid>
                <!-- Dynamic Background XAML Vector -->
                <Viewbox x:Name="HeroBackgroundViewbox" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-20,0" Width="140" Height="140" Stretch="Uniform" Opacity="0.08">
                    <Path x:Name="HeroBackgroundPath" Fill="White" Data="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41.39.39 1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41.39.39 1.03.39 1.41 0l1.06-1.06z" />
                </Viewbox>
                
                <!-- Small Colored Vector Icon (Truly Transparent) -->
                <Viewbox x:Name="HeroStatusIconViewbox" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,15,0" Width="48" Height="48" Stretch="Uniform" Opacity="1">
                    <Path x:Name="HeroStatusIconPath" Fill="#fbbf24" Data="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41.39.39 1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41.39.39 1.03.39 1.41 0l1.06-1.06z" />
                </Viewbox>
                <StackPanel Margin="20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="NextPrayerNameText" Text="Asr" Foreground="White" FontSize="28" FontWeight="Bold"/>
                        <TextBlock x:Name="HeroJamaatText" Text="Jamaat: 05:00 PM" Foreground="White" Opacity="0.85" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="12,0,0,6"/>
                    </StackPanel>
                    <TextBlock x:Name="HeroStatusText" Text="ends in" Foreground="White" Opacity="0.75" FontSize="12" Margin="0,3,0,0"/>
                    <TextBlock x:Name="CountdownText" Text="02:15:30" Foreground="White" FontSize="32" FontWeight="Bold"/>
                    <TextBlock x:Name="HeroContextNoteText" Text="✨ Context Note here" Foreground="#fbbf24" FontSize="12" FontWeight="Medium" Margin="0,5,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                    
                    <!-- Tahajjud Hero Timer -->
                    <Border x:Name="TahajjudHeroDisplay" Background="#336366F1" CornerRadius="6" Padding="10,6" Margin="0,10,0,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🌙 Tahajjud" Foreground="#e0e7ff" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text=" (ends at Fajr)" Foreground="White" Opacity="0.8" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="TahajjudHeroTimerText" Grid.Column="1" Text="01:20:30" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Nafal Notice Hero -->
                    <Border x:Name="NafalNoticeHero" Background="#3310B981" CornerRadius="6" Padding="10,6" Margin="0,10,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="✨" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="NafalNoticeText" Text="Salat al-Duha time is active" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ProgressBar x:Name="PrayerProgress" Height="4" Margin="0,15,0,0" Value="60" Maximum="100" Background="#33FFFFFF" Foreground="#10b981" BorderThickness="0"/>
                    
                    <UniformGrid Columns="2" Margin="0,15,0,0">
                        <TextBlock x:Name="HeroSunriseText" Text="&#x2600; Sunrise: --" Foreground="White" Opacity="0.85" FontSize="12" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="HeroSunsetText" Text="&#x1F315; Sunset: --" Foreground="White" Opacity="0.85" FontSize="12" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                    </UniformGrid>

                    <!-- Prohibited Times Warning -->
                    <Border x:Name="ProhibitedWarning" Background="#4dff0000" CornerRadius="4" Padding="8,4" Margin="0,15,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="ProhibitedText" Text="⚠️ Prohibited Prayer Time (Sunset)" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Prayer List -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Hidden" Margin="15,0,15,15">
            <StackPanel>
                <!-- Daily Highlights: Suhur & Iftar -->
                <TextBlock Text="Daily Highlights" FontWeight="Bold" FontSize="13" Margin="0,6,0,4" Foreground="White" Opacity="0.8"/>
                <UniformGrid Columns="2" Margin="0,0,0,6">
                    <Border x:Name="SuhurCard" Background="#1AFFFFFF" CornerRadius="6" Padding="8" Margin="0,0,5,0">
                        <StackPanel>
                            <TextBlock x:Name="SuhurDateText" Text="Today, Apr 7" FontSize="9" Foreground="White" Opacity="0.6" Margin="0,0,0,2"/>
                            <TextBlock x:Name="SuhurNameText" Text="Suhur (Ends)" FontSize="10" FontWeight="SemiBold" Foreground="White" Opacity="0.7"/>
                            <TextBlock x:Name="SuhurTimeText" Text="--:-- AM" FontSize="14" FontWeight="Bold" Foreground="#60a5fa"/>
                            <TextBlock x:Name="SuhurCountdownText" Text="--:--:--" FontSize="10" Foreground="White" Opacity="0.8" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="IftarCard" Background="#1AFFFFFF" CornerRadius="6" Padding="8">
                        <StackPanel>
                            <TextBlock x:Name="IftarDateText" Text="Today, Apr 7" FontSize="9" Foreground="White" Opacity="0.6" Margin="0,0,0,2"/>
                            <TextBlock x:Name="IftarNameText" Text="Iftar (Begins)" FontSize="10" FontWeight="SemiBold" Foreground="White" Opacity="0.7"/>
                            <TextBlock x:Name="IftarTimeText" Text="--:-- PM" FontSize="14" FontWeight="Bold" Foreground="#f87171"/>
                            <TextBlock x:Name="IftarCountdownText" Text="--:--:--" FontSize="10" Foreground="White" Opacity="0.8" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
                
                <!-- Fasting Highlights Note -->
                <Border x:Name="FastingNoteBorder" Background="#33FFFFFF" BorderBrush="#4DFFFFFF" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,10" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="✨" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock x:Name="FastingNoteText" Grid.Column="1" Text="Sunnah Fasting Today" Foreground="White" FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Prohibited Times (Now below highlights) -->
                <TextBlock Text="Prohibited Times" FontWeight="Bold" FontSize="13" Margin="0,6,0,4" Foreground="White" Opacity="0.8"/>
                <UniformGrid Columns="3" Margin="0,0,0,8">
                    <Border x:Name="SunriseProhibCard" Background="#4dff0000" CornerRadius="4" Padding="3" Margin="0,0,3,0">
                        <StackPanel>
                             <TextBlock Text="Sunrise" FontSize="9" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="SunriseProhibTimer" Text="--:--:--" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="SunriseProhibRange" Text="--:-- AM" FontSize="7" Foreground="#dddddd" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ZawalProhibCard" Background="#4dff0000" CornerRadius="4" Padding="3" Margin="0,0,3,0">
                        <StackPanel>
                             <TextBlock Text="Zawal" FontSize="9" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="ZawalProhibTimer" Text="--:--:--" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="ZawalProhibRange" Text="--:-- AM" FontSize="7" Foreground="#dddddd" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SunsetProhibCard" Background="#4dff0000" CornerRadius="4" Padding="3">
                        <StackPanel>
                             <TextBlock Text="Sunset" FontSize="9" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="SunsetProhibTimer" Text="--:--:--" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="SunsetProhibRange" Text="--:-- PM" FontSize="7" Foreground="#dddddd" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Prayer List with Ranges -->
                <TextBlock Text="Today's Prayer Times" FontWeight="Bold" FontSize="13" Margin="0,6,0,4" Foreground="White" Opacity="0.8"/>
                <Border x:Name="FajrCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <TextBlock x:Name="FajrNameText" Text="Fajr" FontSize="15" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="FajrTimeText" Text="--:-- AM - --:-- AM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="SunriseCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <TextBlock x:Name="SunriseNameText" Text="Sunrise" FontSize="15" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="SunriseTimeText" Text="--:-- AM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="DhuhrCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <TextBlock x:Name="DhuhrNameText" Text="Dhuhr" FontSize="15" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="DhuhrTimeText" Text="--:-- PM - --:-- PM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="AsrCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <TextBlock x:Name="AsrNameText" Text="Asr" FontSize="15" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="AsrTimeText" Text="--:-- PM - --:-- PM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="MaghribCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,6">
                    <Grid>
                        <TextBlock x:Name="MaghribNameText" Text="Maghrib" FontSize="15" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="MaghribTimeText" Text="--:-- PM - --:-- PM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="IshaCard" Background="#1AFFFFFF" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock x:Name="IshaNameText" Text="Isha" FontSize="15" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="IshaTimeText" Text="--:-- PM - --:-- AM" FontSize="13" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                
                <!-- Nafal Prayers -->
                <TextBlock Text="Nafal Prayers" FontWeight="Bold" FontSize="13" Margin="0,10,0,4" Foreground="White" Opacity="0.8"/>
                <StackPanel Margin="0,0,0,5">
                    <!-- Duha (Ishraq) -->
                    <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10" Margin="0,0,0,4">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Salat al-Duha (Ishraq)" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="After sunrise until just before Zawal" FontSize="10" Foreground="#9ca3af" Margin="0,1,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="DuhaTimeText" Text="--:-- AM - --:-- PM" FontSize="11" FontWeight="Bold" Foreground="#60a5fa" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    <!-- Awwabin -->
                    <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10" Margin="0,0,0,4">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Awwabin" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Between Maghrib and Isha" FontSize="10" Foreground="#9ca3af" Margin="0,1,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="AwwabinTimeText" Text="--:-- PM - --:-- PM" FontSize="11" FontWeight="Bold" Foreground="#60a5fa" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    <!-- Tahajjud -->
                    <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10" Margin="0,0,0,4">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Tahajjud" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="After Isha until Fajr" FontSize="10" Foreground="#9ca3af" Margin="0,1,0,0"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="TahajjudTimeText" Text="--:-- PM - --:-- AM" FontSize="11" FontWeight="Bold" Foreground="#60a5fa" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="LastThirdTimeText" Text="Last 1/3: --:-- AM" FontSize="9" FontWeight="SemiBold" Foreground="#fcd34d" HorizontalAlignment="Right" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border x:Name="FooterBorder" Grid.Row="4" Background="#170939" Padding="10">
            <TextBlock Text="© 2026 Abiruzzaman Molla. All Rights Reserved." Foreground="White" Opacity="0.85" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>

</Window>
