                            <TextBlock Text="TODAY" FontSize="9" Foreground="White" Opacity="0.6" Margin="0,0,0,2"/>
                            <TextBlock Text="{DynamicResource Label_IAmFasting}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="{DynamicResource Label_MarkFasting}" FontSize="9" Foreground="White" Opacity="0.7"/>
                        </StackPanel>
                    </CheckBox>
                </UniformGrid>
                
                <Border x:Name="FastingNoteBorder" Background="#33FFFFFF" BorderBrush="#4DFFFFFF" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,10,0,10" Visibility="Collapsed">
