                        </StackPanel>
                    </Grid>
                </Border>
                <Border x:Name="IshaCard" Style="{StaticResource PremiumCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
