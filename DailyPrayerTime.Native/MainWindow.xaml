                    </Border>

                    <Border x:Name="ZawalProhibCard" Background="#4dff0000" CornerRadius="8" Padding="8" Margin="0,0,3,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Label_Zawal}" FontSize="11" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ZawalProhibTimer" Text="--:--:--" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ZawalProhibRange" Text="--:-- AM" FontSize="9" Foreground="White" Opacity="0.8" HorizontalAlignment="Center"/>
