                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0">
                            <TextBlock x:Name="FastingNoteText" Text="Sunnah Fasting Today" Foreground="White" FontWeight="SemiBold" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,40,0"/>
