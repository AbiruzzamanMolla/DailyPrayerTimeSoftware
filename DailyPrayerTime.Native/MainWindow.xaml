<Window x:Class="DailyPrayerTime.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}" 
        Height="600" 
        Width="570" 
        MinWidth="570" 
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown"
        Icon="pack://application:,,,/icon.ico"
        xmlns:local="clr-namespace:DailyPrayerTime.Native">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      CornerRadius="0" 
                      GlassFrameThickness="0" 
                      UseAeroCaptionButtons="False" 
                      NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Gradients and Styles matching the React App -->
        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#064E3B" Offset="0"/>
            <GradientStop Color="#022C22" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="PremiumCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#2AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="15,12"/>
        </Style>
        <Style x:Key="HeroDeedChipStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="ChipBorder" 
                                Background="#1AFFFFFF" 
                                BorderBrush="#25FFFFFF" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="8,5"
                                Margin="2">
                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Border x:Name="CheckRect" CornerRadius="3" BorderBrush="#AFFFFFFF" BorderThickness="1.2"/>
                                    <Path x:Name="CheckIcon" Data="M3,7 L5,9 L9,5" Stroke="#10B981" StrokeThickness="2" Visibility="Collapsed"/>
                                </Grid>
                                <ContentPresenter x:Name="Content" Grid.Column="1" VerticalAlignment="Center">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="#3310B981"/>
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="#6010B981"/>
                                <Setter TargetName="CheckRect" Property="BorderBrush" Value="#10B981"/>
                                <Setter TargetName="CheckRect" Property="Background" Value="#10B981"/>
                                <Setter TargetName="CheckIcon" Property="Stroke" Value="White"/>
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="#26FFFFFF"/>
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="#48FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BottomTabStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#34d399"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#10FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Border Background="#065F46" CornerRadius="15" BorderBrush="#20FFFFFF" BorderThickness="1">
        <Grid x:Name="MainGrid" Background="{StaticResource MainGradient}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> <!-- Custom Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Update Banner -->
                <RowDefinition x:Name="MainContentRow" Height="*"/> <!-- Main Content Area -->
                <RowDefinition x:Name="FooterRow" Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#111827">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>   <!-- Left: Icon + App Name -->
                    <ColumnDefinition Width="Auto"/> <!-- Right: Controls -->
                </Grid.ColumnDefinitions>

                <!-- Left: App Icon + Name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False">
                    <Image Source="pack://application:,,,/icon.ico" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,7,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{DynamicResource AppTitleUpper}"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Opacity="0.75"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,5,0" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="RamadanBtn" Click="RamadanMode_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="{DynamicResource ToolTip_Ramadan}" Margin="0,0,5,0">
                        <TextBlock x:Name="RamadanIcon" Text="🕌" FontSize="16" FontWeight="Bold" Foreground="White" Opacity="1.0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <Button x:Name="ZenModeBtn" Click="ZenMode_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="{DynamicResource ToolTip_ZenMode}" Margin="0,0,5,0">
                        <TextBlock x:Name="ZenModeIcon" Text="✦" FontSize="16" FontWeight="Bold" Foreground="White" Opacity="1.0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <Button x:Name="SettingsBtn" Click="Settings_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,10,0">
                        <TextBlock x:Name="SettingsIcon" Text="⚙" FontSize="16" Foreground="White" Opacity="1.0" />
                    </Button>

                    <Border Width="1" Height="20" Background="#20FFFFFF" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <Button Click="Minimize_Click" Style="{StaticResource ToolbarButtonStyle}">
                        <TextBlock Text="─" FontSize="12" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Click="Maximize_Click" Style="{StaticResource ToolbarButtonStyle}">
                        <TextBlock Text="☐" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                    </Button>
                    <Button Click="Close_Click" Style="{StaticResource ToolbarButtonStyle}" Foreground="#EF4444">
                        <TextBlock Text="✕" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>


        <StackPanel Grid.Row="1" Margin="15,10,15,0">
            <Border x:Name="UpdateBanner" Margin="0,0,0,10" CornerRadius="8" Background="#fbbf24" Padding="12,8" Visibility="Collapsed" Cursor="Hand" MouseLeftButtonUp="UpdateBanner_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="✨" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="UpdateTitleText" Text="{DynamicResource Update_Available}" Foreground="#170939" FontWeight="Bold" FontSize="14" />
                        <TextBlock x:Name="UpdateVersionText" Text="{DynamicResource Update_Ready}" Foreground="#170939" FontSize="11" Opacity="0.8" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{DynamicResource Update_Download}" Foreground="#170939" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border x:Name="ApiNoticeBanner" Margin="0,0,0,10" CornerRadius="8" Background="#10B981" Padding="12,12" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="ApiNoticeTitleText" Text="Title" Foreground="White" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" Margin="0,0,0,4" />
                        
                        <Border HorizontalAlignment="Left" Background="#20FFFFFF" CornerRadius="4" Padding="6,2" Margin="0,0,0,6">
                            <TextBlock x:Name="ApiNoticeHeaderText" Text="Notification Message" Foreground="White" FontWeight="SemiBold" FontSize="11" />
                        </Border>
                        
                        <TextBlock x:Name="ApiNoticeMessageText" Text="Message" Foreground="White" FontSize="13" Opacity="0.9" TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1" Click="ApiNoticeDismiss_Click" VerticalAlignment="Top" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4">
                        <TextBlock Text="✕" Foreground="White" FontSize="14" Opacity="0.8"/>
                    </Button>
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="2">
            <ScrollViewer x:Name="PrayerListScroll" VerticalScrollBarVisibility="Hidden">
                <Grid x:Name="CenteringWrapper" MinHeight="{Binding ActualHeight, ElementName=PrayerListScroll}">
                    <StackPanel x:Name="MainContentStack" VerticalAlignment="Center" Margin="15,10">
                        <Border x:Name="HeroBorder" Margin="0,0,0,12" CornerRadius="16" Background="#170939" ClipToBounds="True">
            <Grid>
                <Viewbox x:Name="HeroBackgroundViewbox" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-20,0" Width="140" Height="140" Stretch="Uniform" Opacity="0.05">
                    <Path x:Name="HeroBackgroundPath" Fill="White" Data="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1z" />
                </Viewbox>
                
                <StackPanel Margin="20,12">
                    <Grid x:Name="BasmalaHeaderGrid" HorizontalAlignment="Center" Margin="0,0,0,4"
                          Cursor="Hand" MouseEnter="BasmalaHeader_MouseEnter" MouseLeave="BasmalaHeader_MouseLeave">
                        <TextBlock x:Name="BasmalaArabicText"
                                   Text="إِنَّ الْحَمْدَ لِلَّهِ، وَالصَّلَاةُ وَالسَّلَامُ عَلَى رَسُولِ اللَّهِ"
                                   Foreground="White" Opacity="0.8" FontSize="13"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" FontFamily="Traditional Arabic, Segoe UI"
                                   FlowDirection="RightToLeft"/>
                        <TextBlock x:Name="BasmalaTranslationText"
                                   Text="" Foreground="White" Opacity="0"
                                   FontSize="11" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap"
                                   FontStyle="Italic"/>
                    </Grid>

                    <Viewbox MaxHeight="30" HorizontalAlignment="Center">
                        <TextBlock x:Name="HeroLocationText" Text="Loading..." Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </Viewbox>

                    <TextBlock x:Name="HeroTimeUntilLabel" Text="{DynamicResource Label_Calculating}" HorizontalAlignment="Center" Foreground="White" Opacity="0.8" FontSize="11" Margin="0,4,0,0"/>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="Auto" MinWidth="150" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="HeroSunriseDisplay" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Opacity="0.8">
                            <Path Width="16" Height="16" Fill="White" Data="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1z" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="HeroSunriseTime" Text="--:--" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <TextBlock Text="{DynamicResource Prayer_Sunrise}" Foreground="White" Opacity="0.6" FontSize="8" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Viewbox Grid.Column="1" MaxHeight="60" HorizontalAlignment="Center">
                            <TextBlock x:Name="HeroCountdownText" Text="00:00:00" Foreground="White" FontSize="41" FontWeight="Bold"/>
                        </Viewbox>

                        <StackPanel x:Name="HeroSunsetDisplay" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.8">
                            <Path Width="16" Height="16" Fill="White" Data="M10,2L12,4L10,6M21,14L19,12L21,10M12,21L10,19L12,17M3,10L5,12L3,14M12,6C8.7,6,6,8.7,6,12s2.7,6,6,6s6-2.7,6-6S15.3,6,12,6z" Opacity="0.4" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="HeroSunsetTime" Text="--:--" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <TextBlock Text="{DynamicResource Prayer_Sunset}" Foreground="White" Opacity="0.6" FontSize="8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="HeroContextNoteText" Text="" HorizontalAlignment="Center" Foreground="#FBBF24" FontSize="11" Margin="0,4,0,0" Visibility="Collapsed"/>
                    <StackPanel x:Name="TahajjudHeroDisplay" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource Tahajjud_EndsIn}" Foreground="White" Opacity="0.8" FontSize="11"/>
                        <TextBlock x:Name="TahajjudHeroTimerText" Text="00:00:00" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <Border x:Name="NafalNoticeHero" Background="#1AFFFFFF" CornerRadius="8" Padding="10,5" Margin="0,5,0,0" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="NafalNoticeText" Text="" Foreground="White" FontSize="11"/>
                    </Border>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="HeroPrevPrayerName" Text="Isha" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                            <TextBlock x:Name="HeroPrevPrayerTime" Text="7:34" Foreground="White" Opacity="0.7" FontSize="10"/>
                        </StackPanel>
                        <ProgressBar x:Name="HeroProgressBar" Grid.Column="1" Height="5" Value="50" Margin="12,0" VerticalAlignment="Center" Background="#1AFFFFFF" Foreground="White" BorderThickness="0"/>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                            <TextBlock x:Name="HeroNextPrayerName" Text="Fajr" Foreground="White" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="HeroNextPrayerTime" Text="4:23" Foreground="White" Opacity="0.7" FontSize="10" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="HeroPrayerNote" Text="" Foreground="White" Opacity="0.7" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" MaxWidth="300" FontWeight="SemiBold"/>

                    <Border x:Name="HeroMiniGridsBorder" Margin="0,15,0,0" Background="#14FFFFFF" CornerRadius="12" Padding="12,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock x:Name="HeroSubDate" Text="--" Foreground="White" Opacity="0.9" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HeroSubDay" Text="--" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HeroSubHijri" Text="--" Foreground="White" Opacity="0.9" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            
                            <Grid x:Name="HeroRamadanGrid" Visibility="Collapsed" Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Label_SuhurEnds}" Foreground="White" Opacity="0.7" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="HeroSuhurTime" Text="--:--" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        <TextBlock x:Name="HeroSuhurStatus" Text="--:--:--" Foreground="White" Opacity="0.8" FontSize="9" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#1AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="5,0,5,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Label_IftarBegins}" Foreground="White" Opacity="0.7" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="HeroIftarTime" Text="--:--" Foreground="#f87171" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        <TextBlock x:Name="HeroIftarStatus" Text="--:--:--" Foreground="White" Opacity="0.8" FontSize="9" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            
                             <Grid x:Name="HeroDefaultGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Prayer_Fajr}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubFajrTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock x:Name="DhuhrLabel" Text="{DynamicResource Prayer_Dhuhr}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubDhuhrTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock x:Name="AsrLabel" Text="Asr" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubAsrTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock x:Name="MaghribLabel" Text="Maghrib" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubMaghribTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="2" Background="#0AFFFFFF" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="8" Padding="5" Margin="2">
                                    <StackPanel>
                                        <TextBlock x:Name="IshaLabel" Text="Isha" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="SubIshaTime" Text="--:--" Foreground="White" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="HeroTrackerBox" 
                            Background="#26FFFFFF" 
                            CornerRadius="12" 
                            Padding="12,15" 
                            Margin="0,15,0,0"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            Visibility="Visible">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock x:Name="HeroTrackerTitle" Text="TRACKER" FontSize="11" Opacity="0.8" Foreground="White" Margin="4,0,0,0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HeroTrackerProgress" Text="0/0 Completed" Foreground="White" Opacity="0.6" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl x:Name="HeroRakatList" HorizontalContentAlignment="Stretch">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}" 
                                                  IsChecked="{Binding IsChecked}" 
                                                  Style="{StaticResource HeroDeedChipStyle}"
                                                  Checked="RakatCheck_Changed" 
                                                  Unchecked="RakatCheck_Changed"
                                                  Tag="{Binding Key}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                        </StackPanel>
                    </Grid>
                </Border>

            <Border x:Name="ProhibitedWarning" Background="#4dff0000" CornerRadius="6" Padding="8,4" Margin="0,10,0,10" Visibility="Collapsed">
                <TextBlock x:Name="ProhibitedText" Text="{DynamicResource Prohibited_Warning}" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </Border>
            
            <Grid x:Name="HighlightsHeader" Margin="0,6,0,6">
                <TextBlock Text="{DynamicResource Section_Highlights}" FontWeight="Bold" FontSize="13" Foreground="White" Opacity="0.8" VerticalAlignment="Center"/>
            </Grid>
