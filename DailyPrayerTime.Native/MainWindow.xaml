                            </Button>
                        </Grid>
                        
                        <StackPanel x:Name="FastingNoteExtraContent" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed">
                            <TextBlock x:Name="FastingNoteDetailsText" Foreground="White" Opacity="0.9" FontSize="10.5" TextWrapping="Wrap" LineHeight="16"/>
                        </StackPanel>
                    </Grid>
                </Border>

