<Window x:Class="DailyPrayerTime.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Daily Prayer Timer" Height="750" Width="400"
        MinHeight="600" MinWidth="350"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#170939">
    <Window.Resources>
        <!-- Gradients and Styles matching the React App -->
        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#d7bedc" Offset="0"/>
            <GradientStop Color="#ecdfee" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>
    
    <Grid Background="{StaticResource MainGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Update Banner -->
            <RowDefinition Height="Auto"/> <!-- Hero Section -->
            <RowDefinition Height="*"/>    <!-- Prayer List -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>
        
        <!-- Header: Location and Settings -->
        <Grid Grid.Row="0" Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="LocationDisplay" Text="📍 Dhaka, Bangladesh" Foreground="#170939" FontWeight="Bold" FontSize="16" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="HijriDateDisplay" Text="18 Ramadan 1447" Foreground="#170939" Opacity="0.6" FontSize="11" HorizontalAlignment="Left" Margin="0,2,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="⚙" Click="Settings_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderBrush="Transparent" Foreground="#170939" FontSize="20" Cursor="Hand" />
        </Grid>

        <!-- Update Notification (Hidden by default) -->
        <Border x:Name="UpdateBanner" Grid.Row="1" Margin="20,0,20,15" CornerRadius="10" Background="#fbbf24" Padding="15,10" Visibility="Collapsed" Cursor="Hand" MouseLeftButtonUp="UpdateBanner_Click">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="✨" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="UpdateTitleText" Text="Update Available!" Foreground="#170939" FontWeight="Bold" FontSize="14" />
                    <TextBlock x:Name="UpdateVersionText" Text="New version is ready." Foreground="#170939" FontSize="11" Opacity="0.8" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="Download →" Foreground="#170939" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Hero Section: Next Prayer Countdown -->
        <Border x:Name="HeroBorder" Grid.Row="2" Margin="20,0,20,20" CornerRadius="12" Background="#170939" Padding="20">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="NextPrayerNameText" Text="Asr" Foreground="White" FontSize="32" FontWeight="Bold"/>
                    <TextBlock x:Name="HeroJamaatText" Text="Jamaat: 05:00 PM" Foreground="White" Opacity="0.85" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="15,0,0,8"/>
                </StackPanel>
                <TextBlock x:Name="HeroStatusText" Text="ends in" Foreground="White" Opacity="0.75" FontSize="14" Margin="0,5,0,0"/>
                <TextBlock x:Name="CountdownText" Text="02:15:30" Foreground="White" FontSize="36" FontWeight="Bold"/>
                
                <ProgressBar x:Name="PrayerProgress" Height="4" Margin="0,15,0,0" Value="60" Maximum="100" Background="#33FFFFFF" Foreground="#10b981" BorderThickness="0"/>
                
                <UniformGrid Columns="2" Margin="0,15,0,0">
                    <TextBlock x:Name="HeroSunriseText" Text="&#x2600; Sunrise: --" Foreground="White" Opacity="0.85" FontSize="12" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="HeroSunsetText" Text="&#x1F315; Sunset: --" Foreground="White" Opacity="0.85" FontSize="12" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                </UniformGrid>

                <!-- Prohibited Times Warning -->
                <Border x:Name="ProhibitedWarning" Background="#4dff0000" CornerRadius="4" Padding="8,4" Margin="0,15,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="ProhibitedText" Text="⚠️ Prohibited Prayer Time (Sunset)" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Prayer List -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Hidden" Margin="20,0,20,20">
            <StackPanel>
                <!-- Daily Highlights: Suhur & Iftar -->
                <TextBlock Text="Daily Highlights" FontWeight="Bold" FontSize="14" Margin="0,10,0,5" Foreground="White" Opacity="0.8"/>
                <UniformGrid Columns="2" Margin="0,0,0,10">
                    <Border x:Name="SuhurCard" Background="#1AFFFFFF" CornerRadius="8" Padding="15" Margin="0,0,5,0">
                        <StackPanel>
                            <TextBlock x:Name="SuhurNameText" Text="Suhur (Ends)" FontSize="12" FontWeight="SemiBold" Foreground="White" Opacity="0.7"/>
                            <TextBlock x:Name="SuhurTimeText" Text="--:-- AM" FontSize="16" FontWeight="Bold" Foreground="#60a5fa"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="IftarCard" Background="#1AFFFFFF" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock x:Name="IftarNameText" Text="Iftar (Begins)" FontSize="12" FontWeight="SemiBold" Foreground="White" Opacity="0.7"/>
                            <TextBlock x:Name="IftarTimeText" Text="--:-- PM" FontSize="16" FontWeight="Bold" Foreground="#f87171"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Prohibited Times (Now below highlights) -->
                <TextBlock Text="Prohibited Times" FontWeight="Bold" FontSize="14" Margin="0,10,0,5" Foreground="White" Opacity="0.8"/>
                <UniformGrid Columns="3" Margin="0,0,0,15">
                    <Border x:Name="SunriseProhibCard" Background="#4dff0000" CornerRadius="6" Padding="5" Margin="0,0,5,0">
                        <StackPanel>
                             <TextBlock Text="Sunrise" FontSize="10" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="SunriseProhibTimer" Text="--:--:--" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="SunriseProhibRange" Text="--:-- AM" FontSize="8" Foreground="#dddddd" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ZawalProhibCard" Background="#4dff0000" CornerRadius="6" Padding="5" Margin="0,0,5,0">
                        <StackPanel>
                             <TextBlock Text="Zawal" FontSize="10" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="ZawalProhibTimer" Text="--:--:--" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="ZawalProhibRange" Text="--:-- AM" FontSize="8" Foreground="#dddddd" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SunsetProhibCard" Background="#4dff0000" CornerRadius="6" Padding="5">
                        <StackPanel>
                             <TextBlock Text="Sunset" FontSize="10" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="SunsetProhibTimer" Text="--:--:--" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                             <TextBlock x:Name="SunsetProhibRange" Text="--:-- PM" FontSize="8" Foreground="#dddddd" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Prayer List with Ranges -->
                <Border x:Name="FajrCard" Background="#1AFFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock x:Name="FajrNameText" Text="Fajr" FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="FajrTimeText" Text="--:-- AM - --:-- AM" FontSize="14" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="SunriseCard" Background="#1AFFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock x:Name="SunriseNameText" Text="Sunrise" FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="SunriseTimeText" Text="--:-- AM" FontSize="14" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="DhuhrCard" Background="#1AFFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock x:Name="DhuhrNameText" Text="Dhuhr" FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="DhuhrTimeText" Text="--:-- PM - --:-- PM" FontSize="14" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="AsrCard" Background="#1AFFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock x:Name="AsrNameText" Text="Asr" FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="AsrTimeText" Text="--:-- PM - --:-- PM" FontSize="14" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="MaghribCard" Background="#1AFFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock x:Name="MaghribNameText" Text="Maghrib" FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="MaghribTimeText" Text="--:-- PM - --:-- PM" FontSize="14" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border x:Name="IshaCard" Background="#1AFFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <TextBlock x:Name="IshaNameText" Text="Isha" FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="IshaTimeText" Text="--:-- PM - --:-- AM" FontSize="14" FontWeight="Bold" Foreground="#34d399" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border x:Name="FooterBorder" Grid.Row="4" Background="#170939" Padding="10">
            <TextBlock Text="© 2026 Abiruzzaman Molla. All Rights Reserved." Foreground="White" Opacity="0.85" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>

</Window>
