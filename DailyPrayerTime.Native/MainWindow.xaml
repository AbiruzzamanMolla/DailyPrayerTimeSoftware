    <local:TasbihView x:Name="TasbihViewControl" Visibility="Collapsed" Margin="15,0,15,15"/>
    <local:RamadanView x:Name="RamadanViewControl" Visibility="Collapsed" Margin="15,0,15,15"/>
</Grid>


        <Border x:Name="FooterNavigationBar" Grid.Row="3" Background="#170939" BorderBrush="#1AFFFFFF" BorderThickness="0,1,0,0">
