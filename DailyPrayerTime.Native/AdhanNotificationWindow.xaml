<Window x:Class="DailyPrayerTime.Native.AdhanNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource i18n_Title_AdhanNotification}" Height="Auto" Width="550"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" SizeToContent="Height">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="#1e1e1e" CornerRadius="20" BorderBrush="#333" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.5" ShadowDepth="2"/>
        </Border.Effect>
        <StackPanel Margin="25,20">
            <!-- Header -->
            <TextBlock x:Name="PrayerTitleText" Text="Time for {0}" 
                       HorizontalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
            
            <TextBlock x:Name="PrayerTimeRangeText" Text="05:30 AM - 06:45 AM" 
                       HorizontalAlignment="Center" FontSize="14" Foreground="#999" Margin="0,0,0,2"/>
            
            <TextBlock x:Name="JamaatTimeText" Text="Jamaat: {0}" 
                       HorizontalAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="#10b981" Margin="0,0,0,20"/>

            <!-- Separator -->
            <Border Height="1" Background="#333" Margin="0,0,0,20"/>

            <!-- Dua Section -->
            <TextBlock Text="{DynamicResource i18n_Label_AdhanDua}" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,10" TextDecorations="Underline"/>
            
            <TextBlock Text="{DynamicResource i18n_Adhan_DuaArabic}" 
                       TextWrapping="Wrap" TextAlignment="Center" FontSize="18" Foreground="#eee" Margin="0,0,0,15" LineHeight="28"/>
            
            <TextBlock Text="{DynamicResource i18n_Adhan_DuaTransliteration}" 
                       TextWrapping="Wrap" TextAlignment="Center" FontSize="13" Foreground="#888" FontStyle="Italic" Margin="0,0,0,10" LineHeight="20"/>

            <TextBlock Text="{DynamicResource i18n_Adhan_DuaTranslation}" 
                       TextWrapping="Wrap" TextAlignment="Center" FontSize="12" Foreground="#666" Margin="0,0,0,25" LineHeight="18"/>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="{DynamicResource i18n_Btn_Close}" Style="{StaticResource ActionButton}" Background="#2a2a2a" Click="Close_Click" Margin="0,0,5,0"/>
                <Button x:Name="MuteBtn" Grid.Column="1" Content="{DynamicResource i18n_Btn_Mute}" Style="{StaticResource ActionButton}" Foreground="#ef4444" Background="#2a2a2a" Click="Mute_Click" Margin="5,0,0,0"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
