<Window x:Class="DailyPrayerTime.Native.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prayer Overlay" Height="90" Width="240" x:Name="OverlayRoot"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">
    <Window.Resources>
        <Storyboard x:Key="ExpandAnim">
            <DoubleAnimation Storyboard.TargetName="OverlayBorder" Storyboard.TargetProperty="Height" To="80" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction><PowerEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ExtraDetails" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="CollapseAnim">
            <DoubleAnimation Storyboard.TargetName="OverlayBorder" Storyboard.TargetProperty="Height" To="34" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><PowerEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ExtraDetails" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
        </Storyboard>
    </Window.Resources>
    
    <Grid VerticalAlignment="Bottom">
        <Border Background="#DB022c22" CornerRadius="3" BorderBrush="#22FFFFFF" BorderThickness="1" 
                MouseEnter="Border_MouseEnter" MouseLeave="Border_MouseLeave" 
                MouseLeftButtonDown="Border_MouseLeftButtonDown" x:Name="OverlayBorder" 
                VerticalAlignment="Bottom" Height="34">
            <Grid>
                <!-- Main compact row (Always at bottom) -->
                <StackPanel x:Name="MainInfo" Orientation="Horizontal" VerticalAlignment="Bottom" Height="32" Margin="8,0">
                    <Border Width="3" Height="14" Background="#10b981" CornerRadius="1" Margin="0,0,8,0"/>
                    <TextBlock x:Name="OverlayNameText" Text="Fajr ends in:" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="OverlayCountdownText" Text="00:00:00" Foreground="#2ECC71" FontSize="12" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Expanded Details (Above) -->
                <StackPanel x:Name="ExtraDetails" Orientation="Vertical" Opacity="0" Margin="10,5,10,35" VerticalAlignment="Bottom">
                    <TextBlock x:Name="ToolTipCurrentText" Text="Current: --" Foreground="#B0B0B0" FontSize="10" Margin="0,0,0,2" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ToolTipNextText" Text="Next: --" Foreground="#B0B0B0" FontSize="10" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
