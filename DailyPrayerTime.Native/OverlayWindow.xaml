<Window x:Class="DailyPrayerTime.Native.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prayer Overlay" Height="30" Width="160" x:Name="OverlayRoot"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">
    <Window.Resources>
        <Storyboard x:Key="ExpandAnim">
            <DoubleAnimation Storyboard.TargetName="OverlayRoot" Storyboard.TargetProperty="Width" To="350" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction><PowerEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ExtraDetails" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="CollapseAnim">
            <DoubleAnimation Storyboard.TargetName="OverlayRoot" Storyboard.TargetProperty="Width" To="160" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><PowerEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ExtraDetails" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
        </Storyboard>
    </Window.Resources>
    
    <Border Background="#CC022c22" CornerRadius="4" BorderBrush="#33FFFFFF" BorderThickness="1" 
            MouseEnter="Border_MouseEnter" MouseLeave="Border_MouseLeave" 
            MouseLeftButtonDown="Border_MouseLeftButtonDown" x:Name="OverlayBorder">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
            <!-- Normal Content (Always Visible) -->
            <StackPanel Orientation="Horizontal" Width="140">
                <Border Width="3" Height="14" Background="#10b981" CornerRadius="1" Margin="0,0,8,0"/>
                <TextBlock x:Name="OverlayNameText" Text="Fajr ends in:" Foreground="#B0B0B0" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock x:Name="OverlayCountdownText" Text="00:00:00" Foreground="#2ECC71" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Expanded Details (Fades in) -->
            <StackPanel x:Name="ExtraDetails" Orientation="Horizontal" Opacity="0" Margin="10,0,0,0">
                <TextBlock x:Name="ToolTipCurrentText" Text="Current: --" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock x:Name="ToolTipNextText" Text="Next: --" Foreground="#B0B0B0" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
