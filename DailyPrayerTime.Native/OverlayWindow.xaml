<Window x:Class="DailyPrayerTime.Native.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prayer Overlay" Height="34" SizeToContent="Width"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">
    <Border Background="#A6042f2e" CornerRadius="6" BorderBrush="#26FFFFFF" BorderThickness="1" Padding="12,0" x:Name="OverlayBorder">
        <Border.ToolTip>
            <ToolTip>
                <StackPanel>
                    <TextBlock x:Name="ToolTipCurrentText" FontWeight="Bold" Text="Current: --"/>
                    <TextBlock x:Name="ToolTipNextText" Foreground="#666666" Text="Next: --"/>
                </StackPanel>
            </ToolTip>
        </Border.ToolTip>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Green indicator line -->
            <Border Width="2" Height="12" Background="#00ff00" CornerRadius="1" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="#00ff00" BlurRadius="4" ShadowDepth="0"/>
                </Border.Effect>
            </Border>
            
            <TextBlock x:Name="OverlayNameText" Text="Next:" Foreground="#99FFFFFF" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="OverlayCountdownText" Text="--:--" Foreground="#00ff00" FontSize="14" FontFamily="Consolas" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>
    </Border>
</Window>
