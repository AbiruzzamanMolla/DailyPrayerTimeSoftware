<Window x:Class="DailyPrayerTime.Native.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prayer Overlay" 
        Height="75" 
        Width="200" 
        x:Name="OverlayRoot"
        Icon="pack://application:,,,/icon.ico"
        WindowStyle="None" 
        ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">
    <Window.Resources>
        <Storyboard x:Key="ExpandAnim">
            <DoubleAnimation Storyboard.TargetName="OverlayBorder" Storyboard.TargetProperty="Height" To="68" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction><PowerEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ExtraDetails" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="CollapseAnim">
            <DoubleAnimation Storyboard.TargetName="OverlayBorder" Storyboard.TargetProperty="Height" To="34" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><PowerEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ExtraDetails" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
        </Storyboard>
    </Window.Resources>
    
    <Grid VerticalAlignment="Bottom">
        <Border Background="#DB022c22" CornerRadius="3" BorderBrush="#22FFFFFF" BorderThickness="1" 
                MouseEnter="Border_MouseEnter" MouseLeave="Border_MouseLeave" 
                MouseLeftButtonDown="Border_MouseLeftButtonDown" x:Name="OverlayBorder" 
                VerticalAlignment="Bottom" Height="34">
            <Grid>
                <!-- Dynamic Background XAML Vector -->
                <Viewbox x:Name="OverlayBackgroundViewbox" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-5,0" Width="40" Height="40" Stretch="Uniform" Opacity="0.1">
                    <Path x:Name="OverlayBackgroundPath" Fill="White" Data="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41.39.39 1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41.39.39 1.03.39 1.41 0l1.06-1.06z" />
                </Viewbox>
                <!-- Main compact row (Always at bottom) -->
                <StackPanel x:Name="MainInfo" Orientation="Horizontal" VerticalAlignment="Bottom" Height="32" Margin="8,0">
                    <Border Width="3" Height="14" Background="#10b981" CornerRadius="1" Margin="0,0,8,0"/>
                    <TextBlock x:Name="OverlayNameText" Text="{DynamicResource i18n_Label_Calculating}" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="OverlayCountdownText" Text="00:00:00" Foreground="#2ECC71" FontSize="12" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Expanded Details (Above) -->
                    <StackPanel x:Name="ExtraDetails" Orientation="Vertical" Opacity="0" Margin="10,5,10,35" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource i18n_Label_Current}" Foreground="#B0B0B0" FontSize="10" Margin="0,0,3,2"/>
                            <TextBlock x:Name="ToolTipCurrentText" Text="--" Foreground="#B0B0B0" FontSize="10" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource i18n_Label_Upcoming}" Foreground="#B0B0B0" FontSize="10" Margin="0,0,3,0"/>
                            <TextBlock x:Name="ToolTipNextText" Text="--" Foreground="#B0B0B0" FontSize="10" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
