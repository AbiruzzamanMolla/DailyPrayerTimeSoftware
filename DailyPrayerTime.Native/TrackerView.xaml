<UserControl x:Class="DailyPrayerTime.Native.TrackerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="400">
    
    <UserControl.Resources>
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#2AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="BulletBorder" Width="18" Height="18" 
                                        CornerRadius="5" Background="#20FFFFFF" 
                                        BorderBrush="#40FFFFFF" BorderThickness="1.5">
                                    <TextBlock x:Name="CheckMark" Text="✓" Foreground="White" 
                                               FontSize="12" FontWeight="Bold" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                                               Visibility="Collapsed"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BulletBorder" Property="Background" Value="#34D399"/>
                                <Setter TargetName="BulletBorder" Property="BorderBrush" Value="#34D399"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BulletBorder" Property="BorderBrush" Value="#34D399"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="18,18,18,0">
                
                <!-- Mini Status Row (Appears when Hero is hidden) -->
                <Border Style="{StaticResource GlassCard}" Padding="12,8" Margin="0,0,0,15" Background="#20111827">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="NOW:" Foreground="White" Opacity="0.6" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="MiniPrayerName" Text="DHUHR" Foreground="#34D399" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                             <TextBlock x:Name="MiniCountdown" Text="01:23:45" Foreground="White" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                             <TextBlock Text="LEFT" Foreground="White" Opacity="0.5" FontSize="9" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Header -->
                <Grid Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Divine Tracker" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Visualize your spiritual journey" Foreground="#D1D5DB" FontSize="12" Opacity="0.8" Margin="2,2,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#10B981" CornerRadius="8" Padding="8,4" Margin="0,0,0,4">
                            <TextBlock x:Name="CurrentDateLabel" Text="13 APR" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Border>
                        <TextBlock x:Name="HijriDateLabel" Text="24 RAMADAN 1445 AH" Foreground="White" Opacity="0.5" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>

                <!-- Tab Navigation -->
                <ListBox x:Name="TrackerTabList" 
                         Background="Transparent" BorderThickness="0" 
                         SelectionChanged="TrackerTab_Changed" 
                         Margin="0,0,0,20">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="TabBorder" Padding="15,8" CornerRadius="18" Margin="0,0,10,0" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="TabBorder" Property="Background" Value="#10B981"/>
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#34D399"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter TargetName="TabBorder" Property="Background" Value="#10FFFFFF"/>
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#20FFFFFF"/>
                                                <Setter Property="Foreground" Value="#AFFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#40FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem x:Name="TabDaily" Content="Daily" IsSelected="True"/>
                    <ListBoxItem x:Name="TabWeekly" Content="Weekly"/>
                    <ListBoxItem x:Name="TabMonthly" Content="Monthly"/>
                    <ListBoxItem x:Name="TabYearly" Content="Yearly"/>
                </ListBox>

                <!-- History Aggregate Title -->
                <StackPanel x:Name="HistoryHeader" Visibility="Collapsed" Margin="0,0,0,14">
                    <Button x:Name="TrackerBackButton" Click="TrackerBack_Click" Visibility="Collapsed"
                            HorizontalAlignment="Left" Margin="0,0,0,10"
                            Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BackBorder" Background="#15FFFFFF" CornerRadius="20"
                                        BorderBrush="#25FFFFFF" BorderThickness="1" Padding="10,5">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#x2190;" Foreground="#34D399" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="BACK" Foreground="#D1D5DB" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BackBorder" Property="Background" Value="#25FFFFFF"/>
                                        <Setter TargetName="BackBorder" Property="BorderBrush" Value="#40FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="HistorySectionTitle" Text="LAST 7 DAYS" Foreground="White" Opacity="0.5" FontSize="10" FontWeight="Bold"/>
                </StackPanel>

                <!-- COMMON COMPLETION CARD -->
                <Border x:Name="OverallProgressCard" Style="{StaticResource GlassCard}" Background="#1F2937" Padding="20">
                    <StackPanel>
                        <Grid>
                            <TextBlock x:Name="OverallProgressTitle" Text="{DynamicResource Tracker_DailyCompletion}" Foreground="White" Opacity="0.7" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="OverallProgressPercent" Text="0%" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,15,0,0">
                            <!-- Background Bar -->
                            <Border Height="12" Background="#20FFFFFF" CornerRadius="6"/>
                            <!-- Glass Progress Fill -->
                            <ProgressBar x:Name="MainProgressBar" Value="0" Height="12" BorderThickness="0" Background="Transparent" Foreground="#34D399">
                                <ProgressBar.Template>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid>
                                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="6">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="#10B981" Offset="0"/>
                                                        <GradientStop Color="#34D399" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border Background="#40FFFFFF" Margin="0,1,0,3" CornerRadius="4" Opacity="0.5"/>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </ProgressBar.Template>
                            </ProgressBar>
                        </Grid>
                        
                        <!-- Stats Row -->
                        <Grid Margin="0,15,0,0">
                             <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Tracker_Completed}" Foreground="White" Opacity="0.5" FontSize="10" FontWeight="Bold" Margin="0,0,4,0"/>
                                <TextBlock x:Name="StatsCompletedCount" Text="0" Foreground="#34D399" FontSize="10" FontWeight="Bold"/>
                             </StackPanel>
                             <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Tracker_Missed}" Foreground="White" Opacity="0.5" FontSize="10" FontWeight="Bold" Margin="0,0,4,0"/>
                                <TextBlock x:Name="StatsMissedCount" Text="0" Foreground="#F87171" FontSize="10" FontWeight="Bold"/>
                             </StackPanel>
                        </Grid>
                        
                        <Grid x:Name="SawmGrid" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal" x:Name="SawmIndicator">
                                <Border Width="8" Height="8" CornerRadius="4" Background="#FBBF24" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="FASTING ACTIVE" Foreground="#FBBF24" FontSize="10" FontWeight="Bold"/>
                            </StackPanel>
                            <CheckBox x:Name="SawmToggle" Content="FASTING TODAY?" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Click="SawmToggle_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Daily View Content -->
                <StackPanel x:Name="DailySection">
                    <!-- Daily Prayers Grid -->
                <TextBlock Text="MANDATORY PRAYERS" Foreground="White" Opacity="0.6" FontSize="11" FontWeight="Bold" Margin="4,8,0,12"/>
                <ItemsControl x:Name="PrayerList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="Opacity" Value="0.6"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <BlurEffect Radius="3" KernelType="Gaussian"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding PrayerName}" Foreground="White" FontWeight="Bold" FontSize="15"/>
                                            <Border Background="#20FFFFFF" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CompletionText}" Foreground="#34D399" FontSize="9" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Deeds}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}" 
                                                          IsEnabled="{Binding IsEnabled}"
                                                          Margin="0,0,16,10" 
                                                          Click="RakatCheck_Click">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.6"/>
                                                                    <Setter Property="Effect">
                                                                        <Setter.Value>
                                                                            <BlurEffect Radius="2"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Nafal Section -->
                <TextBlock Text="EXTRA WORSHIP &amp; NAFAL" Foreground="White" Opacity="0.6" FontSize="11" FontWeight="Bold" Margin="4,15,0,12"/>
                
                <!-- Specialized Nafal Card -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <!-- Duha -->
                        <Grid Margin="0,0,0,15" x:Name="DuhaGrid">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.6"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <BlurEffect Radius="3"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <TextBlock Text="DUHA / ISHRAQ" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="Sunnah Mu'akkadah" Foreground="#34D399" FontSize="9" FontWeight="Bold" Opacity="0.8"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Width="28" Height="28" Click="NafalCount_Click" Tag="Duha:-2" Background="#1AFFFFFF">
                                    <TextBlock Text="-" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                                <TextBlock x:Name="DuhaCount" Text="0" Width="35" TextAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                <Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Width="28" Height="28" Click="NafalCount_Click" Tag="Duha:2" Background="#1AFFFFFF">
                                    <TextBlock Text="+" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="#1AFFFFFF" Margin="0,5,0,15"/>

                        <!-- Awwabin -->
                        <Grid Margin="0,0,0,15" x:Name="AwwabinGrid">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.6"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <BlurEffect Radius="3"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <TextBlock Text="AWWABIN" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="After Maghrib" Foreground="#34D399" FontSize="9" FontWeight="Bold" Opacity="0.8"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Width="28" Height="28" Click="NafalCount_Click" Tag="Awwabin:-2" Background="#1AFFFFFF">
                                    <TextBlock Text="-" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                                <TextBlock x:Name="AwwabinCount" Text="0" Width="35" TextAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                <Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Width="28" Height="28" Click="NafalCount_Click" Tag="Awwabin:2" Background="#1AFFFFFF">
                                    <TextBlock Text="+" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="#1AFFFFFF" Margin="0,5,0,15"/>

                        <!-- Tahajjud -->
                        <Grid x:Name="TahajjudGrid">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.6"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <BlurEffect Radius="3"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <TextBlock Text="TAHAJJUD" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="Night Prayer" Foreground="#34D399" FontSize="9" FontWeight="Bold" Opacity="0.8"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Width="28" Height="28" Click="NafalCount_Click" Tag="Tahajjud:-2" Background="#1AFFFFFF">
                                    <TextBlock Text="-" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                                <TextBlock x:Name="TahajjudCount" Text="0" Width="35" TextAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                <Button Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Width="28" Height="28" Click="NafalCount_Click" Tag="Tahajjud:2" Background="#1AFFFFFF">
                                    <TextBlock Text="+" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Calendar Grid (For Monthly/Yearly detailed views) -->
            <UniformGrid x:Name="CalendarGrid" Columns="7" Margin="0,0,0,20" Visibility="Collapsed">
                <!-- Days of week headers will be added in code behind -->
            </UniformGrid>

            <!-- Aggregate List (For Yearly Month List / Weekly Day List) -->
            <ItemsControl x:Name="HistoryList" Visibility="Collapsed">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Click="HistoryItem_Click" Tag="{Binding FullDate}" Margin="4" Width="85" Height="100" Padding="0" BorderThickness="0" Background="Transparent">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="12" Background="#1AFFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1" Name="BtnBorder">
                                        <Grid>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding DateLabel}" Foreground="White" FontSize="10" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,8" Opacity="0.8"/>
                                                <Grid Width="45" Height="45">
                                                    <Ellipse Stroke="#20FFFFFF" StrokeThickness="3"/>
                                                    <Ellipse Stroke="#34D399" StrokeThickness="3" StrokeDashArray="100" Name="ProgressRing"/>
                                                    <TextBlock Text="{Binding ProgressText}" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#25FFFFFF"/>
                                            <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#4034D399"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Qadha Summary Card -->
            <Border x:Name="QadhaSummaryCard" Style="{StaticResource GlassCard}" Background="#2D1B36" Padding="20" Margin="0,10,0,20">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="{DynamicResource Tracker_QadhaSummary}" Foreground="White" Opacity="0.7" FontSize="10" FontWeight="Bold"/>
                    </Grid>
                    <StackPanel Margin="0,15,0,0">
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource Tracker_Today}" Foreground="#D1D5DB" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="QadhaTodayCount" Text="0" Foreground="#F87171" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource Tracker_ThisWeek}" Foreground="#D1D5DB" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="QadhaWeekCount" Text="0" Foreground="#F87171" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource Tracker_ThisMonth}" Foreground="#D1D5DB" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="QadhaMonthCount" Text="0" Foreground="#F87171" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="{DynamicResource Tracker_ThisYear}" Foreground="#D1D5DB" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="QadhaYearCount" Text="0" Foreground="#F87171" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>

        <!-- Docked Footer Navigation -->
        <Border Grid.Row="1" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Padding="15,10">
            <Button x:Name="CloseBtn" Cursor="Hand" Background="#34D399" Click="Close_Click" Margin="0,0,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="0,8">
                            <TextBlock Text="EXIT TRACKER" Foreground="#064E3B" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="ExtraBold" FontSize="13"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>
    </Grid>
</UserControl>
