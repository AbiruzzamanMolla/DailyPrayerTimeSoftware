<UserControl x:Class="DailyPrayerTime.Native.TasbihView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <StackPanel Margin="15,10">
            <TextBlock Text="{DynamicResource Tasbih_Title}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,5,0,15"/>

            <Border Background="#15FFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="15,12" Margin="0,0,0,8">
                <StackPanel>
                    <WrapPanel x:Name="PhrasePanel" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                </StackPanel>
            </Border>

            <Border Background="#15FFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="15,12" Margin="0,0,0,8"
                    MouseLeftButtonUp="TapArea_MouseUp" Cursor="Hand">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Direction="-90" ShadowDepth="2" Opacity="0.15" RenderingBias="Quality"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📿" FontSize="36" HorizontalAlignment="Center" Margin="0,5,0,5"/>
                    <TextBlock x:Name="CountText" Text="0" Foreground="White" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,5"/>
                    <TextBlock x:Name="PhraseText" Text="" Foreground="#34d399" FontSize="22" FontFamily="Traditional Arabic, Segoe UI" HorizontalAlignment="Center" Margin="0,5,0,5"/>
                    <TextBlock Text="{DynamicResource Tasbih_TapHint}" Foreground="White" Opacity="0.4" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#1AFFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="15,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="44" Height="44" Background="#2AFFFFFF" CornerRadius="22" Cursor="Hand" MouseLeftButtonUp="Decrement_Click">
                        <TextBlock Text="−" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="PhraseNameText" Text="" Foreground="White" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="2" Width="44" Height="44" Background="#2AFFFFFF" CornerRadius="22" Cursor="Hand" Margin="0,0,8,0" MouseLeftButtonUp="Reset_Click">
                        <TextBlock Text="↺" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="3" Width="44" Height="44" Background="#2AFFFFFF" CornerRadius="22" Cursor="Hand" MouseLeftButtonUp="Target_Click">
                        <TextBlock x:Name="TargetText" Text="33" Foreground="#fbbf24" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Background="#1AFFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="15,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Tasbih_TotalToday}" Foreground="White" Opacity="0.6" FontSize="11" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TotalText" Text="0" Foreground="#34d399" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
