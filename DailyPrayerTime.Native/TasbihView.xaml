<UserControl x:Class="DailyPrayerTime.Native.TasbihView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <StackPanel Margin="12,8,12,10">
            <Border Background="#170939" CornerRadius="10" Padding="4" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="TabTasbih" Grid.Column="0" Background="#3310B981" CornerRadius="8" Padding="8,5" Cursor="Hand" MouseLeftButtonUp="SwitchToTasbih">
                        <TextBlock Text="📿  Tasbih" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>
                    <Border x:Name="TabDuas" Grid.Column="1" Background="#1AFFFFFF" CornerRadius="8" Padding="8,5" Cursor="Hand" MouseLeftButtonUp="SwitchToDuas">
                        <TextBlock Text="📖  Duas" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <StackPanel x:Name="TasbihPanel">
                <Border Background="#15FFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="12,10" Margin="0,0,0,6">
                    <WrapPanel x:Name="PhrasePanel" HorizontalAlignment="Center"/>
                </Border>

                <Border Background="#15FFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="12,10" Margin="0,0,0,6"
                        MouseLeftButtonUp="TapArea_MouseUp" Cursor="Hand">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Direction="-90" ShadowDepth="2" Opacity="0.15" RenderingBias="Quality"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📿" FontSize="30" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                        <TextBlock x:Name="CountText" Text="0" Foreground="White" FontSize="52" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                        <TextBlock x:Name="PhraseText" Text="" Foreground="#34d399" FontSize="18" FontFamily="Traditional Arabic, Segoe UI" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                        <TextBlock Text="{DynamicResource Tasbih_TapHint}" Foreground="White" Opacity="0.4" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#1AFFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="12,10" Margin="0,0,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="38" Height="38" Background="#2AFFFFFF" CornerRadius="19" Cursor="Hand" MouseLeftButtonUp="Decrement_Click">
                            <TextBlock Text="−" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,0">
                            <TextBlock x:Name="PhraseNameText" Text="" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Border Grid.Column="2" Width="38" Height="38" Background="#2AFFFFFF" CornerRadius="19" Cursor="Hand" Margin="0,0,6,0" MouseLeftButtonUp="Reset_Click">
                            <TextBlock Text="↺" Foreground="White" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="3" Width="38" Height="38" Background="#2AFFFFFF" CornerRadius="19" Cursor="Hand" MouseLeftButtonUp="Target_Click">
                            <TextBlock x:Name="TargetText" Text="33" Foreground="#fbbf24" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Background="#1AFFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Tasbih_TotalToday}" Foreground="White" Opacity="0.6" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalText" Text="0" Foreground="#34d399" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="DuasPanel" Visibility="Collapsed">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="📖  Duas &amp; Supplications" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#170939" CornerRadius="6" Padding="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="LangEnBtn" Grid.Column="0" Background="#10B981" CornerRadius="4" Padding="10,4" Cursor="Hand" MouseLeftButtonUp="LangEn_Click">
                                <TextBlock Text="English" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>
                            <Border x:Name="LangBnBtn" Grid.Column="1" Background="Transparent" CornerRadius="4" Padding="10,4" Cursor="Hand" MouseLeftButtonUp="LangBn_Click">
                                <TextBlock Text="বাংলা" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
                <ItemsControl x:Name="DuasList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1AFFFFFF" CornerRadius="10" BorderBrush="#2AFFFFFF" BorderThickness="1" Margin="0,0,0,6" Cursor="Hand" MouseLeftButtonUp="ToggleDuaCard">
                                <StackPanel>
                                    <Grid Margin="12,11,12,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Foreground="#fcd34d" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="1" CornerRadius="4" Width="20" Height="20" Background="#10FFFFFF" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Arrow}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <Border Background="#0A111111" Padding="12,0,12,11" Margin="0" Visibility="{Binding ContentVisibility}">
                                        <StackPanel>
                                            <Border Background="#15111111" CornerRadius="8" Padding="12,10">
                                                <TextBlock Text="{Binding Arabic}" Foreground="White" FontSize="16" FontFamily="Traditional Arabic, Segoe UI" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" FlowDirection="RightToLeft"/>
                                            </Border>
                                            <TextBlock Text="{Binding Transliteration}" Foreground="White" FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,8,0,4"/>
                                            <TextBlock Text="{Binding Translation}" Foreground="White" FontSize="11" Opacity="0.85" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Reference}" Foreground="#9ca3af" FontSize="9" Opacity="0.6" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
