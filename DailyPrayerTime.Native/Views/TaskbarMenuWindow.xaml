<Window x:Class="DailyPrayerTime.Native.Views.TaskbarMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Daily Prayer Time Menu" 
        Height="560" 
        Width="320"
        WindowStyle="None" 
        ResizeMode="NoResize"
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#D0374151"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15000000"/>
                                <Setter Property="Foreground" Value="#FF111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Border Background="#F9F5F8FA" CornerRadius="16" BorderBrush="#20000000" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.12" Color="Black"/>
            </Border.Effect>
            
            <Grid Margin="16,14,16,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Date header -->
                    <RowDefinition Height="Auto"/> <!-- Large active prayer -->
                    <RowDefinition Height="*"/>    <!-- Prayer list -->
                    <RowDefinition Height="Auto"/> <!-- Info separator & text -->
                    <RowDefinition Height="Auto"/> <!-- Actions separator & buttons -->
                </Grid.RowDefinitions>

                <!-- 1. Header (Date) -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DateText" 
                               Text="MONDAY, 8 JUNE, 2026" 
                               Foreground="#80374151" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Left"/>
                    <TextBlock Grid.Column="1" x:Name="HijriDateText" 
                               Text="14 DHUL-HIJJAH, 1447" 
                               Foreground="#80374151" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Right"/>
                </Grid>

                <!-- 2. Large Next/Active Prayer Countdown Card -->
                <Border Grid.Row="1" CornerRadius="12" Background="#FFF1F5F9" Padding="12,10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,1,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ActivePrayerNameText" Text="Dhuhr" Foreground="#FF111827" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock x:Name="ActivePrayerCountdownText" Text="in 1:24:42" Foreground="#80374151" FontSize="11" FontWeight="Medium"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" x:Name="ActivePrayerTimeText" Text="1:08 PM" Foreground="#10B981" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- 3. Prayer list -->
                <StackPanel Grid.Row="2" x:Name="PrayerListPanel" VerticalAlignment="Top">
                    <!-- Standard WPF components for prayers will be generated in code behind or laid out directly here -->
                    <!-- We lay them out directly to ensure premium design, clean margins, and perfect rendering -->
                    <!-- Fajr -->
                    <Border x:Name="Border_Fajr" Grid.ColumnSpan="3" CornerRadius="8" Margin="-4,2" Padding="4,4">
                        <Grid x:Name="Row_Fajr" MinHeight="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Prayer_Fajr}" Margin="4,0,0,0" Foreground="#E0000000" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="Time_Fajr" Text="3:27 AM" Foreground="#B0000000" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Dhuhr -->
                    <Border x:Name="Border_Dhuhr" Grid.ColumnSpan="3" CornerRadius="8" Margin="-4,2" Padding="4,4">
                        <Grid x:Name="Row_Dhuhr" MinHeight="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Prayer_Dhuhr}" Margin="4,0,0,0" Foreground="#E0000000" FontSize="13" VerticalAlignment="Center"/>
                            <Border x:Name="Chip_Dhuhr" Grid.Column="2" Background="#FFF1F5F9" CornerRadius="6" Padding="6,2" Margin="0,0,10,0" Visibility="Collapsed" VerticalAlignment="Center">
                                <TextBlock x:Name="ChipText_Dhuhr" Text="1h 24m" Foreground="#80374151" FontSize="9" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Grid.Column="3" x:Name="Time_Dhuhr" Text="1:08 PM" Foreground="#B0000000" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Asr -->
                    <Border x:Name="Border_Asr" Grid.ColumnSpan="3" CornerRadius="8" Margin="-4,2" Padding="4,4">
                        <Grid x:Name="Row_Asr" MinHeight="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Prayer_Asr}" Margin="4,0,0,0" Foreground="#E0000000" FontSize="13" VerticalAlignment="Center"/>
                            <Border x:Name="Chip_Asr" Grid.Column="2" Background="#FFF1F5F9" CornerRadius="6" Padding="6,2" Margin="0,0,10,0" Visibility="Collapsed" VerticalAlignment="Center">
                                <TextBlock x:Name="ChipText_Asr" Text="--" Foreground="#80374151" FontSize="9" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Grid.Column="3" x:Name="Time_Asr" Text="5:08 PM" Foreground="#B0000000" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Maghrib -->
                    <Border x:Name="Border_Maghrib" Grid.ColumnSpan="3" CornerRadius="8" Margin="-4,2" Padding="4,4">
                        <Grid x:Name="Row_Maghrib" MinHeight="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Prayer_Maghrib}" Margin="4,0,0,0" Foreground="#E0000000" FontSize="13" VerticalAlignment="Center"/>
                            <Border x:Name="Chip_Maghrib" Grid.Column="2" Background="#FFF1F5F9" CornerRadius="6" Padding="6,2" Margin="0,0,10,0" Visibility="Collapsed" VerticalAlignment="Center">
                                <TextBlock x:Name="ChipText_Maghrib" Text="--" Foreground="#80374151" FontSize="9" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Grid.Column="3" x:Name="Time_Maghrib" Text="8:41 PM" Foreground="#B0000000" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Isha -->
                    <Border x:Name="Border_Isha" Grid.ColumnSpan="3" CornerRadius="8" Margin="-4,2" Padding="4,4">
                        <Grid x:Name="Row_Isha" MinHeight="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Prayer_Isha}" Margin="4,0,0,0" Foreground="#E0000000" FontSize="13" VerticalAlignment="Center"/>
                            <Border x:Name="Chip_Isha" Grid.Column="2" Background="#FFF1F5F9" CornerRadius="6" Padding="6,2" Margin="0,0,10,0" Visibility="Collapsed" VerticalAlignment="Center">
                                <TextBlock x:Name="ChipText_Isha" Text="--" Foreground="#80374151" FontSize="9" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Grid.Column="3" x:Name="Time_Isha" Text="10:31 PM" Foreground="#B0000000" FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- 4. Info Section (Location & Calculation Method) -->
                <StackPanel Grid.Row="3" Margin="0,10,0,6">
                    <Separator Background="#15000000" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,2">
                        <TextBlock Text="🌐" FontSize="11" Foreground="#80374151" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="InfoMethodText" Text="Diyanet İşleri (Türkiye)" Foreground="#80374151" FontSize="11" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid Margin="2,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📍" FontSize="11" Foreground="#80374151" Margin="0,1,6,0" VerticalAlignment="Top"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="InfoCoordsText" Text="41.0198, 28.9499" Foreground="#80374151" FontSize="11" FontWeight="Medium"/>
                            <TextBlock x:Name="InfoLocationText" Text="Europe/Istanbul" Foreground="#80374151" FontSize="11" FontWeight="Medium" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- 5. Interactive Action Buttons -->
                <StackPanel Grid.Row="4" Margin="0,4,0,0">
                    <Separator Background="#15000000" Margin="0,0,0,8"/>
                    
                    <Button Style="{StaticResource ActionButtonStyle}" Click="Settings_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Tray_Settings}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource ActionButtonStyle}" Click="OpenHome_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Tray_Open}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource ActionButtonStyle}" Click="Exit_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏻" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Tray_Exit}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
