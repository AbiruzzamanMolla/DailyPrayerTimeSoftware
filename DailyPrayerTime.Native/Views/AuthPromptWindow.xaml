<Window x:Class="DailyPrayerTime.Native.Views.AuthPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cloud Sync"
        Height="320" Width="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="#1a1a2e" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,15">
                <TextBlock Text="☁" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="{DynamicResource Cycle_CloudSync}" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Cycle_SyncEnabled}" FontSize="11" Foreground="White" Opacity="0.6" HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="280"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <Button x:Name="GoogleSignInBtn" Click="GoogleSignIn_Click" Background="#4285F4" Foreground="White" FontSize="13" FontWeight="SemiBold" Padding="20,10" CornerRadius="8" HorizontalAlignment="Stretch" Cursor="Hand" BorderThickness="0" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="G" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Sign in with Google" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock x:Name="ErrorText" Foreground="#f87171" FontSize="10" HorizontalAlignment="Center" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Row="2" Content="{DynamicResource Cancel}" Background="Transparent" BorderBrush="#33FFFFFF" BorderThickness="1" Foreground="White" Padding="20,8" CornerRadius="6" HorizontalAlignment="Center" Click="Cancel_Click" Cursor="Hand" FontSize="11"/>
        </Grid>
    </Border>
</Window>
