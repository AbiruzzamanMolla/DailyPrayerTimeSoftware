<UserControl x:Class="DailyPrayerTime.Native.QiblaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <StackPanel Margin="15,10">
            <TextBlock Text="{DynamicResource Qibla_Title}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,5,0,15"/>

            <Border Background="#15FFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="15,12" Margin="0,0,0,8">
                <StackPanel>
                    <Grid HorizontalAlignment="Center" Width="240" Height="240">
                        <Ellipse Width="220" Height="220" Stroke="#3AFFFFFF" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse Width="200" Height="200" Stroke="#1AFFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse Width="180" Height="180" Stroke="#0FFFFFFF" StrokeThickness="1" StrokeDashArray="4,4" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <TextBlock Text="N" Foreground="#34d399" FontWeight="Bold" FontSize="14" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        <TextBlock Text="S" Foreground="#9ca3af" FontWeight="Bold" FontSize="12" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="E" Foreground="#9ca3af" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <TextBlock Text="W" Foreground="#9ca3af" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0"/>

                        <Polygon x:Name="QiblaArrow" Points="120,25 112,65 128,65" Fill="#34d399" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Polygon.RenderTransform>
                                <RotateTransform x:Name="ArrowRotation" CenterX="120" CenterY="120"/>
                            </Polygon.RenderTransform>
                        </Polygon>

                        <Rectangle x:Name="ArrowShaft" Width="4" Height="65" Fill="#34d399" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,55">
                            <Rectangle.RenderTransform>
                                <RotateTransform x:Name="ShaftRotation" CenterX="2" CenterY="-65"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <Ellipse Width="10" Height="10" Fill="#34d399" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse Width="4" Height="4" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock x:Name="BearingText" Text="--°" Foreground="#34d399" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock x:Name="DirectionText" Text="" Foreground="White" FontSize="12" Opacity="0.7" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock x:Name="LocationText" Text="" Foreground="White" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#1AFFFFFF" CornerRadius="12" BorderBrush="#2AFFFFFF" BorderThickness="1" Padding="15,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Qibla_Note}" Foreground="White" Opacity="0.7" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Border x:Name="RefreshBtn" Background="#10B981" CornerRadius="8" Padding="12,8" Cursor="Hand" HorizontalAlignment="Center" MouseLeftButtonUp="RefreshBtn_Click">
                        <TextBlock Text="{DynamicResource Qibla_Refresh}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
