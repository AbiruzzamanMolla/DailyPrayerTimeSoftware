                                        <TextBlock Text="✅" FontSize="12"/>
                                    </BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#374151" Margin="10,0,0,0"><Bold>Pre-Ramadan Prep:</Bold> A 7-item checklist visible before Ramadan starts. Tick off items like "Set intention," "Stock up on dates," etc. Progress auto-saves.</TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,3,0,2">
