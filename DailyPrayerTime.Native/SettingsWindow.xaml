                                        <TextBlock Text="🧭" FontSize="12"/>
                                    </BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#374151" Margin="10,0,0,0"><Bold>Compass Rose:</Bold> A 240px interactive compass shows North, South, East, and West markers. A green arrow points toward Makkah. The bearing is shown in degrees along with the 16-point compass direction name (N, NNE, NE, etc.).</TextBlock>
                                </BulletDecorator>
                                <BulletDecorator Margin="0,3,0,2">
                                    <BulletDecorator.Bullet>
                                        <TextBlock Text="📍" FontSize="12"/>
                                    </BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#374151" Margin="10,0,0,0"><Bold>Recalculate:</Bold> If you move to a new location or change your coordinates in Settings, tap the Recalculate button to update the Qibla direction instantly.</TextBlock>
                                </BulletDecorator>
                            </StackPanel>
                        </Border>

