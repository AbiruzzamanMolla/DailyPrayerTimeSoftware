<Window x:Class="DailyPrayerTime.Native.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="650" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinWidth="450" MinHeight="600"
        Background="White">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="26" FontWeight="Bold" Foreground="#170939" Margin="0,0,0,15"/>
        
        <TabControl x:Name="SettingsTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#ececec" SelectionChanged="SettingsTabControl_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="#6f6885"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" BorderThickness="0,0,0,2" Margin="0,0,10,0">
                                    <ContentPresenter ContentSource="Header" Margin="10,5"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#170939"/>
                                        <Setter Property="Foreground" Value="#170939"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- TAB 1: DAILY PRAYER -->
            <TabItem Header="Daily Prayer">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,15,10,0">
                    <StackPanel>
                        <!-- Location -->
                        <TextBlock Text="Location" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" Foreground="#170939"/>
                        <TextBlock Text="Name:" Foreground="#6f6885"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LocationNameInput" Padding="5" Margin="0,0,5,0" />
                            <Button Grid.Column="1" Content="Search" Width="60" Click="SearchLocation_Click" Background="#f0f0f0" BorderThickness="1" BorderBrush="#ccc" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Latitude:" Foreground="#6f6885"/>
                                <TextBox x:Name="LatInput" Padding="5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Longitude:" Foreground="#6f6885"/>
                                <TextBox x:Name="LngInput" Padding="5"/>
                            </StackPanel>
                        </Grid>

                        <!-- Calculation Preferences -->
                        <TextBlock Text="Calculation" FontWeight="Bold" FontSize="16" Margin="0,20,0,5" Foreground="#170939"/>
                        <TextBlock Text="Calculation Method:" Foreground="#6f6885"/>
                        <ComboBox x:Name="MethodInput" Margin="0,0,0,10" Padding="5">
                            <ComboBoxItem Content="Shia"/>
                            <ComboBoxItem Content="Karachi"/>
                            <ComboBoxItem Content="ISNA"/>
                            <ComboBoxItem Content="MWL"/>
                            <ComboBoxItem Content="Makkah"/>
                            <ComboBoxItem Content="Egypt"/>
                            <ComboBoxItem Content="Tehran"/>
                            <ComboBoxItem Content="Gulf"/>
                            <ComboBoxItem Content="Kuwait"/>
                            <ComboBoxItem Content="Qatar"/>
                            <ComboBoxItem Content="Singapore"/>
                            <ComboBoxItem Content="France"/>
                            <ComboBoxItem Content="Turkey"/>
                            <ComboBoxItem Content="Russia"/>
                            <ComboBoxItem Content="Moonsighting"/>
                            <ComboBoxItem Content="Dubai"/>
                            <ComboBoxItem Content="JAKIM"/>
                            <ComboBoxItem Content="Tunisia"/>
                            <ComboBoxItem Content="Algeria"/>
                            <ComboBoxItem Content="KEMENAG"/>
                            <ComboBoxItem Content="Morocco"/>
                            <ComboBoxItem Content="Brazil"/>
                            <ComboBoxItem Content="Portugal"/>
                            <ComboBoxItem Content="Jordan"/>
                        </ComboBox>
                        
                        <TextBlock Text="Madhab (Asr):" Foreground="#6f6885"/>
                        <ComboBox x:Name="MadhabInput" Margin="0,0,0,10" Padding="5">
                            <ComboBoxItem Content="Shafi (Standard)"/>
                            <ComboBoxItem Content="Hanafi"/>
                        </ComboBox>

                        <TextBlock Text="Time Format:" Foreground="#6f6885"/>
                        <ComboBox x:Name="TimeFormatInput" Margin="0,0,0,10" Padding="5">
                            <ComboBoxItem Content="12 Hours (AM/PM)"/>
                            <ComboBoxItem Content="24 Hours"/>
                        </ComboBox>

                        <Rectangle Height="1" Fill="#ececec" Margin="0,15"/>

                        <!-- Jamaat Times (Moved Back) -->
                        <TextBlock Text="Jamaat (Congregation) Times" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" Foreground="#170939"/>
                        <TextBlock Text="Set the actual fixed time for Jamaat (HH:mm):" FontSize="12" Foreground="#6f6885" FontStyle="Italic" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Fajr Time:" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="FajrHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="FajrMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="FajrAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="FajrRangeHint" Text="Today: 04:30 - 05:45" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Dhuhr Time:" Grid.Row="1" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="DhuhrHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="DhuhrMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="DhuhrAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="DhuhrRangeHint" Text="Today: 12:05 - 16:30" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Asr Time:" Grid.Row="2" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="AsrHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="AsrMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="AsrAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="AsrRangeHint" Text="Today: 16:30 - 18:15" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Maghrib Time:" Grid.Row="3" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="MaghribHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="MaghribMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="MaghribAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="MaghribRangeHint" Text="Today: 18:15 - 19:45" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Isha Time:" Grid.Row="4" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="IshaHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="IshaMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="IshaAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="IshaRangeHint" Text="Today: 19:45 - 04:30" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="#ececec" Margin="0,15"/>

                        <TextBlock Text="Popup Alarm" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#10b981"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBox x:Name="JamaatPopupOffsetInput" Width="40" Padding="5"/>
                            <TextBlock Text="mins before Jamaat" VerticalAlignment="Center" Foreground="#666" Margin="10,0,0,0"/>
                            <Button Content="Test" Click="TestPopup_Click" Margin="10,0,0,0" Padding="8,2" FontSize="11" Background="#f3f4f6" BorderThickness="1" BorderBrush="#ccc"/>
                        </StackPanel>

                        <TextBlock Text="Adhan &amp; Night Prayer Alarms" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#2563eb"/>
                        <CheckBox x:Name="AdhanAlarmEnabledInput" Content="Enable Adhan sound before Jamaat" Foreground="#170939" Margin="0,0,0,5"/>
                        <CheckBox x:Name="AdhanPopupEnabledInput" Content="Enable Visual Adhan Popup Window" Foreground="#170939" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="AdhanAlarmOffsetInput" Width="40" Padding="5"/>
                            <TextBlock Text="mins before Jamaat" VerticalAlignment="Center" Foreground="#666" Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- Preset Selection -->
                        <TextBlock Text="Select Adhan Preset:" FontSize="12" Foreground="#6f6885" Margin="0,0,0,3"/>
                        <ComboBox x:Name="AdhanPresetCombo" Margin="0,0,0,10" Padding="5" SelectionChanged="AdhanPresetCombo_SelectionChanged" ToolTip="Select from high-quality built-in adhans">
                            <ComboBoxItem Content="-- Select Built-in Adhan track --" Tag=""/>
                            <ComboBoxItem Content="Makkah (Al-Haram)" Tag="Athan_Makkah.mp3"/>
                            <ComboBoxItem Content="Madinah (Al-Nabawi)" Tag="Athan_Madinah_-_Alafasi.mp3"/>
                            <ComboBoxItem Content="Mishary Alafasi" Tag="Athan_Mishary_Alafasi.mp3"/>
                            <ComboBoxItem Content="Abdul Basit" Tag="Athan_Abed_Albase6.mp3"/>
                            <ComboBoxItem Content="Fajr (Malek Chebae)" Tag="Athan_Al-fajer_-_Malek_chebae.mp3"/>
                            <ComboBoxItem Content="Nasser Alqatami" Tag="Athan_Nasser_Alqatami.mp3"/>
                            <ComboBoxItem Content="Mohammad Almenshawy" Tag="Athan_Mohammad_Almenshawy.mp3"/>
                            <ComboBoxItem Content="Custom (Select below)" Tag="CUSTOM"/>
                        </ComboBox>

                        <!-- General sound -->
                        <TextBlock Text="General Adhan Sound:" FontSize="12" Foreground="#6f6885" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AdhanSoundPathInput" Padding="5" IsReadOnly="True" Background="#f3f4f6" ToolTip="Selected General Adhan sound" Grid.Column="0"/>
                            <Button Grid.Column="1" Content="Browse..." Click="BrowseAdhan_Click" Padding="10,0" Margin="5,0,0,0" Height="30"/>
                        </Grid>

                        <!-- Fajr sound -->
                        <TextBlock Text="Fajr-Specific Adhan (Optional):" FontSize="12" Foreground="#6f6885" Margin="0,10,0,3"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FajrAdhanSoundPathInput" Padding="5" IsReadOnly="True" Background="#f3f4f6" ToolTip="Selected Fajr Adhan sound" Grid.Column="0"/>
                            <Button Grid.Column="1" Content="Browse..." Click="FajrBrowseAdhan_Click" Padding="10,0" Margin="5,0,0,0" Height="30"/>
                        </Grid>

                        <!-- Tahajjud sound -->
                        <TextBlock Text="Tahajjud &amp; Night Prayer" FontWeight="SemiBold" FontSize="14" Margin="0,15,0,5" Foreground="#7c3aed"/>
                        <CheckBox x:Name="TahajjudAdhanEnabledInput" Content="Enable Alarm for Tahajjud (Best Time / Last Third)" Foreground="#170939" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,15,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TahajjudAdhanSoundPathInput" Padding="5" IsReadOnly="True" Background="#f3f4f6" ToolTip="Selected Tahajjud sound" Grid.Column="0"/>
                            <Button Grid.Column="1" Content="Browse..." Click="TahajjudBrowseAdhan_Click" Padding="10,0" Margin="5,0,0,0" Height="30"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,20" HorizontalAlignment="Right">
                             <Button x:Name="TestStandardBtn" Content="Test Gen." Click="TestAdhan_Click" Padding="8,0" Cursor="Hand" Height="30" Background="#f3f4f6" BorderBrush="#ccc"/>
                             <Button x:Name="TestFajrBtn" Content="Test Fajr" Click="TestFajrAdhan_Click" Margin="5,0,0,0" Padding="8,0" Cursor="Hand" Height="30" Background="#f3f4f6" BorderBrush="#ccc"/>
                             <Button x:Name="TestTahajjudBtn" Content="Test Tahaj." Click="TestTahajjudAdhan_Click" Margin="5,0,0,0" Padding="8,0" Cursor="Hand" Height="30" Background="#f3f4f6" BorderBrush="#ccc"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: LAYOUT & THEME -->
            <TabItem Header="Layout &amp; Theme">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,15,10,0">
                    <StackPanel>
                        <!-- Integrations -->
                        <TextBlock Text="Windows Integration" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="OverlayInput" Content="Show Floating Prayer Overlay" Margin="0,10,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="UseDeskBandInput" Content="Show Taskbar Prayer Timer (Supports Win 10 / ExplorerPatcher)" Margin="0,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="IntegratedTaskbarInput" Content="Show Integrated Taskbar Timer (Win 11 Source)" Margin="0,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="ShowHeroGridInput" Content="Show Prayer Times Grid in Hero Section" Margin="0,0,0,5" Foreground="#170939"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="NotificationsInput" Content="Enable Prayer Notifications" VerticalAlignment="Center" Foreground="#170939"/>
                            <Button Grid.Column="1" Content="Test" Width="50" Click="TestNotification_Click" Background="#f0f0f0" BorderThickness="1" BorderBrush="#ccc" />
                        </Grid>
                        <CheckBox x:Name="AutoStartInput" Content="Run on Windows Startup" Margin="0,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="SilentStartInput" Content="Run silently on startup (hide main window)" Margin="20,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="ExternalApiInput" Content="Use External API for accuracy (requires internet)" Margin="0,0,0,15" Foreground="#170939"/>

                        <!-- Appearance -->
                        <TextBlock Text="Appearance &amp; Colors" FontWeight="Bold" FontSize="16" Margin="0,15,0,5" Foreground="#170939"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Gradient Start:" Foreground="#3CDA6B"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="GradStartInput" Padding="5"/>
                                    <Button Grid.Column="1" Content="Pick" Click="PickColor_Click" Tag="GradStart" Padding="5,0" Margin="2,0,0,0"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Gradient End:" Foreground="#05813D"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="GradEndInput" Padding="5"/>
                                    <Button Grid.Column="1" Content="Pick" Click="PickColor_Click" Tag="GradEnd" Padding="5,0" Margin="2,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,10,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Primary Color:" Foreground="#6f6885"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PrimaryColorInput" Padding="5"/>
                                    <Button Grid.Column="1" Content="Pick" Click="PickColor_Click" Tag="Primary" Padding="5,0" Margin="2,0,0,0"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Secondary Color:" Foreground="#6f6885"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SecondaryColorInput" Padding="5"/>
                                    <Button Grid.Column="1" Content="Pick" Click="PickColor_Click" Tag="Secondary" Padding="5,0" Margin="2,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 3: SUPPORT & CONTACT -->
            <TabItem Header="Support &amp; Contact">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,15,10,0">
                    <StackPanel>
                        <!-- Section 1: Updates & Version -->
                        <TextBlock Text="Updates" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="#170939"/>
                        <Border Background="#f9f9f9" BorderBrush="#ececec" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Check for application updates to get the latest features and bug fixes." TextWrapping="Wrap" Foreground="#666" FontSize="11"/>
                                        <TextBlock x:Name="VersionDisplay" Text="Version: Native Release 1.8.4" Foreground="#170939" Margin="0,5,0,0" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Check for Updates" Click="CheckForUpdates_Click" Margin="10,0,0,0" Padding="15,6" Background="#170939" Foreground="White" BorderThickness="0" VerticalAlignment="Center">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Section 2: Our Projects -->
                        <TextBlock Text="Our Projects" FontWeight="Bold" FontSize="16" Margin="0,5,0,10" Foreground="#170939"/>
                        <Border Background="#f0fdf4" BorderBrush="#dcfce7" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                            <WrapPanel>
                                <TextBlock Margin="0,0,20,8">
                                    • <Bold>Windows App:</Bold> <Hyperlink NavigateUri="https://github.com/AbiruzzamanMolla/DailyPrayerTimeSoftware" RequestNavigate="Hyperlink_RequestNavigate">GitHub Repo</Hyperlink>
                                </TextBlock>
                                <TextBlock Margin="0,0,20,8">
                                    • <Bold>Chrome Extension:</Bold> <Hyperlink NavigateUri="https://github.com/AbiruzzamanMolla/PrayerTime" RequestNavigate="Hyperlink_RequestNavigate">GitHub Repo</Hyperlink>
                                </TextBlock>
                                <TextBlock Margin="0,0,20,8">
                                    • <Bold>VS Code Extension:</Bold> <Hyperlink NavigateUri="https://marketplace.visualstudio.com/items?itemName=azmolla.prayer-timer-bangladesh" RequestNavigate="Hyperlink_RequestNavigate">Marketplace</Hyperlink>
                                </TextBlock>
                            </WrapPanel>
                        </Border>

                        <!-- Section 3: Sponsors -->
                        <TextBlock Text="Sponsors" FontWeight="Bold" FontSize="16" Margin="0,5,0,10" Foreground="#170939"/>
                        <Border Background="#f5f3ff" BorderBrush="#ede9fe" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                            <StackPanel>
                                <WrapPanel>
                                    <TextBlock Margin="0,0,20,8">
                                        📺 <Hyperlink NavigateUri="https://www.youtube.com/@islamicaudiobook" RequestNavigate="Hyperlink_RequestNavigate">Islamic Audiobook YT</Hyperlink>
                                    </TextBlock>
                                    <TextBlock Margin="0,0,20,8">
                                        📚 <Hyperlink NavigateUri="https://www.youtube.com/@BBPodium" RequestNavigate="Hyperlink_RequestNavigate">Book Review YT (BB Podium)</Hyperlink>
                                    </TextBlock>
                                    <TextBlock Margin="0,0,20,8">
                                        🌐 <Hyperlink NavigateUri="https://audiobookbangla.com" RequestNavigate="Hyperlink_RequestNavigate">Audiobook Bangla</Hyperlink>
                                    </TextBlock>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Section 4: Developer Profile -->
                        <TextBlock Text="Developer Profile" FontWeight="Bold" FontSize="16" Margin="0,5,0,10" Foreground="#170939"/>
                        <Border Background="#f3f4f6" BorderBrush="#e5e7eb" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Abiruzzaman Molla" Foreground="#111827" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                                <TextBlock Foreground="#4b5563" Margin="0,0,15,10">
