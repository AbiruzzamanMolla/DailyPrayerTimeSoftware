<Window x:Class="DailyPrayerTime.Native.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="650" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinWidth="450" MinHeight="600"
        Background="White">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="26" FontWeight="Bold" Foreground="#170939" Margin="0,0,0,15"/>
        
        <TabControl x:Name="SettingsTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#ececec" SelectionChanged="SettingsTabControl_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="#6f6885"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" BorderThickness="0,0,0,2" Margin="0,0,10,0">
                                    <ContentPresenter ContentSource="Header" Margin="10,5"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#170939"/>
                                        <Setter Property="Foreground" Value="#170939"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- TAB 1: DAILY PRAYER -->
            <TabItem Header="Daily Prayer">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,15,10,0">
                    <StackPanel>
                        <!-- Location -->
                        <TextBlock Text="Location" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" Foreground="#170939"/>
                        <TextBlock Text="Name:" Foreground="#6f6885"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LocationNameInput" Padding="5" Margin="0,0,5,0" />
                            <Button Grid.Column="1" Content="Search" Width="60" Click="SearchLocation_Click" Background="#f0f0f0" BorderThickness="1" BorderBrush="#ccc" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Latitude:" Foreground="#6f6885"/>
                                <TextBox x:Name="LatInput" Padding="5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Longitude:" Foreground="#6f6885"/>
                                <TextBox x:Name="LngInput" Padding="5"/>
                            </StackPanel>
                        </Grid>

                        <!-- Calculation Preferences -->
                        <TextBlock Text="Calculation" FontWeight="Bold" FontSize="16" Margin="0,20,0,5" Foreground="#170939"/>
                        <TextBlock Text="Calculation Method:" Foreground="#6f6885"/>
                        <ComboBox x:Name="MethodInput" Margin="0,0,0,10" Padding="5">
                            <ComboBoxItem Content="Shia"/>
                            <ComboBoxItem Content="Karachi"/>
                            <ComboBoxItem Content="ISNA"/>
                            <ComboBoxItem Content="MWL"/>
                            <ComboBoxItem Content="Makkah"/>
                            <ComboBoxItem Content="Egypt"/>
                            <ComboBoxItem Content="Tehran"/>
                            <ComboBoxItem Content="Gulf"/>
                            <ComboBoxItem Content="Kuwait"/>
                            <ComboBoxItem Content="Qatar"/>
                            <ComboBoxItem Content="Singapore"/>
                            <ComboBoxItem Content="France"/>
                            <ComboBoxItem Content="Turkey"/>
                            <ComboBoxItem Content="Russia"/>
                            <ComboBoxItem Content="Moonsighting"/>
                            <ComboBoxItem Content="Dubai"/>
                            <ComboBoxItem Content="JAKIM"/>
                            <ComboBoxItem Content="Tunisia"/>
                            <ComboBoxItem Content="Algeria"/>
                            <ComboBoxItem Content="KEMENAG"/>
                            <ComboBoxItem Content="Morocco"/>
                            <ComboBoxItem Content="Brazil"/>
                            <ComboBoxItem Content="Portugal"/>
                            <ComboBoxItem Content="Jordan"/>
                            <ComboBoxItem Content="Manual"/>
                        </ComboBox>

                        <!-- Advanced Manual Calculation Settings -->
                        <StackPanel x:Name="ManualParamsPanel" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock Text="Advanced Manual Parameters" FontWeight="SemiBold" Foreground="#2563eb" Margin="0,5,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Fajr Angle:" Foreground="#6f6885" FontSize="11"/>
                                    <TextBox x:Name="FajrAngleInput" Padding="5" Text="18.0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Isha Angle:" Foreground="#6f6885" FontSize="11"/>
                                    <TextBox x:Name="IshaAngleInput" Padding="5" Text="18.0"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="High Latitude Rule:" Foreground="#6f6885" FontSize="11" Margin="0,5,0,0"/>
                            <ComboBox x:Name="HighLatRuleInput" Padding="5">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Night Middle"/>
                                <ComboBoxItem Content="Seventh of Night"/>
                                <ComboBoxItem Content="Twilight Angle"/>
                            </ComboBox>
                        </StackPanel>
                        
                        <TextBlock Text="Madhab (Asr):" Foreground="#6f6885"/>
                        <ComboBox x:Name="MadhabInput" Margin="0,0,0,10" Padding="5">
                            <ComboBoxItem Content="Shafi (Standard)"/>
                            <ComboBoxItem Content="Hanafi"/>
                        </ComboBox>

                        <TextBlock Text="Time Format:" Foreground="#6f6885"/>
                        <ComboBox x:Name="TimeFormatInput" Margin="0,0,0,10" Padding="5">
                            <ComboBoxItem Content="12 Hours (AM/PM)"/>
                            <ComboBoxItem Content="24 Hours"/>
                        </ComboBox>

                        <Rectangle Height="1" Fill="#ececec" Margin="0,10"/>

                        <!-- Hijri Adjustment -->
                        <TextBlock Text="Hijri Date Adjustment" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" Foreground="#170939"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Adjustment (Days):" VerticalAlignment="Center" Foreground="#6f6885" Margin="0,0,10,0"/>
                            <ComboBox x:Name="HijriAdjInput" Width="60" Padding="5">
                                <ComboBoxItem Content="-2"/>
                                <ComboBoxItem Content="-1"/>
                                <ComboBoxItem Content="0"/>
                                <ComboBoxItem Content="+1"/>
                                <ComboBoxItem Content="+2"/>
                            </ComboBox>
                            <TextBlock Text="(Fixes discrepancies)" FontStyle="Italic" FontSize="11" VerticalAlignment="Center" Foreground="#999" Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- Suhur/Iftar Adjustments -->
                        <TextBlock Text="Suhur &amp; Iftar Adjustment" FontWeight="Bold" FontSize="16" Margin="0,10,0,5" Foreground="#170939"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Suhur Offset (min):" Foreground="#6f6885" FontSize="12"/>
                                <TextBox x:Name="SuhurOffsetInput" Padding="5" ToolTip="Add/subtract minutes from Suhur time"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Iftar Offset (min):" Foreground="#6f6885" FontSize="12"/>
                                <TextBox x:Name="IftarOffsetInput" Padding="5" ToolTip="Add/subtract minutes from Iftar time"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="#ececec" Margin="0,15"/>

                        <!-- Jamaat Times (Moved Back) -->
                        <TextBlock Text="Jamaat (Congregation) Times" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" Foreground="#170939"/>
                        <TextBlock Text="Set the actual fixed time for Jamaat (HH:mm):" FontSize="12" Foreground="#6f6885" FontStyle="Italic" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Fajr Time:" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="FajrHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="FajrMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="FajrAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="FajrRangeHint" Text="Today: 04:30 - 05:45" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Dhuhr Time:" Grid.Row="1" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="DhuhrHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="DhuhrMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="DhuhrAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="DhuhrRangeHint" Text="Today: 12:05 - 16:30" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Asr Time:" Grid.Row="2" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="AsrHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="AsrMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="AsrAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="AsrRangeHint" Text="Today: 16:30 - 18:15" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Maghrib Time:" Grid.Row="3" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="MaghribHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="MaghribMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="MaghribAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="MaghribRangeHint" Text="Today: 18:15 - 19:45" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Isha Time:" Grid.Row="4" VerticalAlignment="Center" Foreground="#6f6885"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,5">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="IshaHourInput" Width="50" Margin="0,2" SelectionChanged="HourInput_SelectionChanged"/>
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="5,0"/>
                                    <ComboBox x:Name="IshaMinuteInput" Width="50" Margin="0,2"/>
                                    <ComboBox x:Name="IshaAmPmInput" Width="55" Margin="5,2,0,2" Visibility="Collapsed" SelectionChanged="HourInput_SelectionChanged">
                                        <ComboBoxItem Content="AM"/>
                                        <ComboBoxItem Content="PM"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="IshaRangeHint" Text="Today: 19:45 - 04:30" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: NOTIFICATIONS -->
            <TabItem Header="Notifications">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,15,10,0">
                    <StackPanel>
                        <!-- Adhan Controls -->
                        <Border Background="#f8fafc" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Adhan Notifications" FontWeight="Bold" FontSize="16" Foreground="#1e293b" Margin="0,0,0,10"/>
                                <TextBlock Text="Enable sound and visual popup for each prayer:" FontSize="12" Foreground="#64748b" Margin="0,0,0,10"/>
                                
                                <UniformGrid Columns="3" Margin="0,0,0,15">
                                    <CheckBox x:Name="AdhanFajrInput" Content="Fajr" Foreground="#1e293b" Margin="0,5"/>
                                    <CheckBox x:Name="AdhanDhuhrInput" Content="Dhuhr" Foreground="#1e293b" Margin="0,5"/>
                                    <CheckBox x:Name="AdhanAsrInput" Content="Asr" Foreground="#1e293b" Margin="0,5"/>
                                    <CheckBox x:Name="AdhanMaghribInput" Content="Maghrib" Foreground="#1e293b" Margin="0,5"/>
                                    <CheckBox x:Name="AdhanIshaInput" Content="Isha" Foreground="#1e293b" Margin="0,5"/>
                                    <CheckBox x:Name="AdhanPopupEnabledInput" Content="Visual Popup" Foreground="#2563eb" FontWeight="SemiBold" Margin="0,5"/>
                                </UniformGrid>

                                <TextBlock Text="Adhan Volume:" FontSize="12" Foreground="#64748b" Margin="0,5,0,0"/>
                                <Grid Margin="0,5,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="AdhanVolumeInput" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=AdhanVolumeInput, StringFormat={}{0}%}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="#1e293b"/>
                                </Grid>

                                <!-- Audio Selection (Moved here) -->
                                <TextBlock Text="Adhan Sound Selection" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#1e293b"/>
                                <ComboBox x:Name="AdhanPresetCombo" Margin="0,0,0,5" Padding="5" SelectionChanged="AdhanPresetCombo_SelectionChanged" ToolTip="Select built-in audio">
                                    <ComboBoxItem Content="-- Select Built-in Adhan track --" Tag=""/>
                                    <ComboBoxItem Content="Makkah (Al-Haram)" Tag="Athan_Makkah.mp3"/>
                                    <ComboBoxItem Content="Madinah (Al-Nabawi)" Tag="Athan_Madinah_-_Alafasi.mp3"/>
                                    <ComboBoxItem Content="Mishary Alafasi" Tag="Athan_Mishary_Alafasi.mp3"/>
                                    <ComboBoxItem Content="Abdul Basit" Tag="Athan_Abed_Albase6.mp3"/>
                                    <ComboBoxItem Content="Fajr (Malek Chebae)" Tag="Athan_Al-fajer_-_Malek_chebae.mp3"/>
                                    <ComboBoxItem Content="Nasser Alqatami" Tag="Athan_Nasser_Alqatami.mp3"/>
                                    <ComboBoxItem Content="Mohammad Almenshawy" Tag="Athan_Mohammad_Almenshawy.mp3"/>
                                    <ComboBoxItem Content="Custom (Select below)" Tag="CUSTOM"/>
                                </ComboBox>
                                
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="AdhanSoundPathInput" Padding="5" IsReadOnly="True" Background="#f3f4f6" Grid.Column="0"/>
                                    <Button Grid.Column="1" Content="Browse..." Click="BrowseAdhan_Click" Padding="10,0" Margin="5,0,0,0" Height="28"/>
                                </Grid>

                                <TextBlock Text="Fajr-Specific Audio:" FontSize="11" Foreground="#64748b" Margin="0,10,0,2"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FajrAdhanSoundPathInput" Padding="5" IsReadOnly="True" Background="#f3f4f6" Grid.Column="0"/>
                                    <Button Grid.Column="1" Content="Browse..." Click="FajrBrowseAdhan_Click" Padding="10,0" Margin="5,0,0,0" Height="28"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Pre-Adhan Reminders -->
                        <Border Background="#fffbeb" BorderBrush="#fef3c7" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Reminders &amp; Windows Notifications" FontWeight="Bold" FontSize="16" Foreground="#92400e" Margin="0,0,0,5"/>
                                <TextBlock Text="Notify before prayer start (10 mins default):" FontSize="12" Foreground="#b45309" Margin="0,0,0,10"/>
                                
                                <UniformGrid Columns="3" Margin="0,0,0,10">
                                    <CheckBox x:Name="ReminderFajrInput" Content="Fajr" Foreground="#92400e" Margin="0,5"/>
                                    <CheckBox x:Name="ReminderShuruqInput" Content="Sunrise" Foreground="#92400e" Margin="0,5"/>
                                    <CheckBox x:Name="ReminderDhuhrInput" Content="Dhuhr" Foreground="#92400e" Margin="0,5"/>
                                    <CheckBox x:Name="ReminderAsrInput" Content="Asr" Foreground="#92400e" Margin="0,5"/>
                                    <CheckBox x:Name="ReminderMaghribInput" Content="Maghrib" Foreground="#92400e" Margin="0,5"/>
                                    <CheckBox x:Name="ReminderIshaInput" Content="Isha" Foreground="#92400e" Margin="0,5"/>
                                </UniformGrid>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Notify" VerticalAlignment="Center" Foreground="#92400e"/>
                                    <TextBox x:Name="PreAdhanOffsetInput" Width="40" Margin="10,0" Padding="5"/>
                                    <TextBlock Text="minutes before start" VerticalAlignment="Center" Foreground="#92400e"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Jamaat (Established) Reminders -->
                        <Border Background="#f0fdf4" BorderBrush="#dcfce7" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Prayer Established Reminders (Popup)" FontWeight="Bold" FontSize="16" Foreground="#166534" Margin="0,0,0,5"/>
                                <TextBlock Text="Show popup before congregation time at the Mosque:" FontSize="12" Foreground="#15803d" Margin="0,0,0,10"/>
                                
                                <UniformGrid Columns="3" Margin="0,0,0,10">
                                    <CheckBox x:Name="EstablishedFajrInput" Content="Fajr" Foreground="#166534" Margin="0,5"/>
                                    <CheckBox x:Name="EstablishedDhuhrInput" Content="Dhuhr" Foreground="#166534" Margin="0,5"/>
                                    <CheckBox x:Name="EstablishedAsrInput" Content="Asr" Foreground="#166534" Margin="0,5"/>
                                    <CheckBox x:Name="EstablishedMaghribInput" Content="Maghrib" Foreground="#166534" Margin="0,5"/>
                                    <CheckBox x:Name="EstablishedIshaInput" Content="Isha" Foreground="#166534" Margin="0,5"/>
                                </UniformGrid>
                                
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Show" VerticalAlignment="Center" Foreground="#166534"/>
                                    <TextBox x:Name="JamaatPopupOffsetInput" Width="40" Margin="10,0" Padding="5"/>
                                    <TextBlock Text="minutes before Jamaat" VerticalAlignment="Center" Foreground="#166534"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Night Prayer / Tahajjud -->
                        <Border Background="#f5f3ff" BorderBrush="#ede9fe" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Tahajjud &amp; Night Prayer" FontWeight="Bold" FontSize="16" Foreground="#5b21b6" Margin="0,0,0,10"/>
                                <CheckBox x:Name="TahajjudAdhanEnabledInput" Content="Enable Alarm for Tahajjud (Last Third of Night)" Foreground="#5b21b6" Margin="0,0,0,10"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TahajjudAdhanSoundPathInput" Padding="5" IsReadOnly="True" Background="#f3f4f6" Grid.Column="0"/>
                                    <Button Grid.Column="1" Content="Browse..." Click="TahajjudBrowseAdhan_Click" Padding="10,0" Margin="5,0,0,0" Height="28"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Right">
                                     <Button x:Name="TestStandardBtn" Content="Test Adhan" Click="TestAdhan_Click" Padding="10,0" Cursor="Hand" Height="28" Background="#f8fafc" BorderBrush="#cbd5e1"/>
                                     <Button x:Name="TestTahajjudBtn" Content="Test Tahaj." Click="TestTahajjudAdhan_Click" Margin="5,0,0,0" Padding="10,0" Cursor="Hand" Height="28" Background="#f8fafc" BorderBrush="#cbd5e1"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: LAYOUT & THEME -->
            <TabItem Header="Layout &amp; Theme">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,15,10,0">
                    <StackPanel>
                        <!-- Integrations -->
                        <TextBlock Text="Windows Integration" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="OverlayInput" Content="Show Floating Prayer Overlay" Margin="0,10,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="UseDeskBandInput" Content="Show Taskbar Prayer Timer (Supports Win 10 / ExplorerPatcher)" Margin="0,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="IntegratedTaskbarInput" Content="Show Integrated Taskbar Timer (Win 11 Source)" Margin="0,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="ShowHeroGridInput" Content="Show Prayer Times Grid in Hero Section" Margin="0,0,0,5" Foreground="#170939"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="NotificationsInput" Content="Enable Prayer Notifications" VerticalAlignment="Center" Foreground="#170939"/>
                            <Button Grid.Column="1" Content="Test" Width="50" Click="TestNotification_Click" Background="#f0f0f0" BorderThickness="1" BorderBrush="#ccc" />
                        </Grid>
                        <CheckBox x:Name="AutoStartInput" Content="Run on Windows Startup" Margin="0,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="SilentStartInput" Content="Run silently on startup (hide main window)" Margin="20,0,0,5" Foreground="#170939"/>
                        <CheckBox x:Name="ExternalApiInput" Content="Use External API for accuracy (requires internet)" Margin="0,0,0,15" Foreground="#170939"/>

                        <!-- Appearance -->
                        <TextBlock Text="Appearance &amp; Colors" FontWeight="Bold" FontSize="16" Margin="0,15,0,5" Foreground="#170939"/>
