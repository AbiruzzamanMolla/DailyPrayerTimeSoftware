                                        <TextBlock Text="📊" FontSize="12"/>
                                    </BulletDecorator.Bullet>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#374151" Margin="10,0,0,0"><Bold>Status Banner:</Bold> Shows your current Ramadan day (1-30) with a progress bar. Before Ramadan, it counts down the days until the first fast.</TextBlock>
