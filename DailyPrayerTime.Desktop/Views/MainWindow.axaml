<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DailyPrayerTime.Desktop.ViewModels"
        xmlns:local="using:DailyPrayerTime.Desktop.Views"
        xmlns:models="using:DailyPrayerTime.Shared.Models"
        x:Class="DailyPrayerTime.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Daily Prayer Timer"
        Width="450" Height="620"
        MinWidth="420" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#022C22">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Background="#065F46" Padding="12,6">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="Daily Prayer Timer" FontSize="13" FontWeight="Bold" Foreground="White" Opacity="0.85"/>
                    <TextBlock x:Name="HijriText" FontSize="10" Foreground="#A0D4B0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="10">
                    <TextBlock x:Name="ClockText" FontSize="12" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="#022C22" BorderThickness="0">
            <!-- HOME -->
            <TabItem Header="🏠 Home">
                <ScrollViewer>
                    <StackPanel Margin="12">
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentPrayer}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Countdown}" FontSize="38" FontWeight="Bold" Foreground="#10B981" FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding NextPrayer}" FontSize="12" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Margin="0,8,0,0">
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel>
                                    <TextBlock Text="{Binding HijriDisplay}" FontSize="11" Foreground="#FBBF24" Opacity="0.9"/>
                                    <TextBlock Text="{Binding GregorianDisplay}" FontSize="10" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="Qibla" FontSize="9" Foreground="#9CA3AF" Opacity="0.6"/>
                                    <TextBlock Text="{Binding QiblaBearingText}" FontSize="14" FontWeight="Bold" Foreground="#10B981"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- QIBLA -->
            <TabItem Header="🧭 Qibla">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12">
                    <Border Classes="card" Width="240" Height="240" Padding="0">
                        <Grid>
                            <Ellipse Width="200" Height="200" Stroke="#3AFFFFFF" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="180" Height="180" Stroke="#1AFFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="N" Foreground="#10B981" FontWeight="Bold" FontSize="13" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                            <TextBlock Text="S" Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                            <TextBlock Text="E" Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                            <TextBlock Text="W" Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0"/>
                            <Polygon Points="120,20 112,65 128,65" Fill="#10B981" RenderTransformOrigin="50%,50%">
                                <Polygon.RenderTransform>
                                    <RotateTransform Angle="{Binding QiblaAngle}"/>
                                </Polygon.RenderTransform>
                            </Polygon>
                            <Ellipse Width="8" Height="8" Fill="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding QiblaBearingText}" FontSize="20" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding QiblaDirection}" FontSize="12" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding QiblaLocation}" FontSize="10" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                </StackPanel>
            </TabItem>

            <!-- TASBIH -->
            <TabItem Header="📿 Tasbih">
                <StackPanel Margin="12">
                    <TextBlock Text="📿 Digital Tasbih" Classes="section-title"/>
                    <Border Classes="card" Padding="10,8">
                        <WrapPanel x:Name="PhrasePanel" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Classes="card" Margin="0,6,0,0" Cursor="Hand" PointerPressed="TasbihTap">
                        <StackPanel HorizontalAlignment="Center" Margin="15">
                            <TextBlock Text="📿" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TbCount" Text="0" FontSize="52" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TbPhrase" Text="..." FontSize="16" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <TextBlock x:Name="TbTapHint" Text="Tap to count" FontSize="9" Foreground="#9CA3AF" Opacity="0.5" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="card" Margin="0,6,0,0" Padding="10">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <Border Grid.Column="0" Width="38" Height="38" Background="#2AFFFFFF" CornerRadius="19" Cursor="Hand" PointerPressed="TasbihDec">
                                <TextBlock Text="−" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="TbLabel" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Width="38" Height="38" Background="#2AFFFFFF" CornerRadius="19" Cursor="Hand" Margin="0,0,5,0" PointerPressed="TasbihReset">
                                <TextBlock Text="↺" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" Width="38" Height="38" Background="#2AFFFFFF" CornerRadius="19" Cursor="Hand" PointerPressed="TasbihTarget">
                                <TextBlock x:Name="TbTarget" Text="33" Foreground="#FBBF24" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    <Border Classes="card" Margin="0,6,0,0" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="Total Today" FontSize="9" Foreground="#9CA3AF" Opacity="0.6" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TbTotal" Text="0" FontSize="22" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- RAMADAN -->
            <TabItem Header="🌙 Ramadan">
                <ScrollViewer>
                    <StackPanel Margin="12">
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock x:Name="RamadanStatus" Text="{Binding RamadanStatus}" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <Border Background="#1AFFFFFF" CornerRadius="6" Margin="0,8,0,0" Padding="0">
                                    <ProgressBar x:Name="RamadanProgress" Value="{Binding RamadanDay}" Maximum="30" Height="6" Foreground="#10B981" Background="#1AFFFFFF"/>
                                </Border>
                                <TextBlock x:Name="RamadanProgressText" Text="{Binding RamadanDayDisplay}" FontSize="10" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="card" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="Dua of the Day" FontSize="12" FontWeight="Bold" Foreground="#FBBF24" Margin="0,0,0,6"/>
                                <Border Background="#15111111" CornerRadius="6" Padding="10,8">
                                    <TextBlock x:Name="RamadanDuaArabic" FontSize="14" Foreground="White" FontFamily="Traditional Arabic, Segoe UI" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="RamadanDuaTrans" FontSize="10" Foreground="White" Opacity="0.75" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                <TextBlock x:Name="RamadanDuaTranslation" FontSize="10" Foreground="White" Opacity="0.55" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Classes="card" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="Eid al-Fitr" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="EidCountdownText" Text="{Binding EidCountdown}" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TRACKER -->
            <TabItem Header="📊 Tracker">
                <ScrollViewer>
                    <StackPanel Margin="12">
                        <TextBlock Text="📊 Daily Tracker" Classes="section-title"/>
                        <Border Classes="card">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <Border x:Name="TrackDayBtn" Background="#10B981" CornerRadius="6" Padding="12,5" Cursor="Hand" PointerPressed="TrackShowDay">
                                        <TextBlock Text="Day" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <Border x:Name="TrackWeekBtn" Background="#1AFFFFFF" CornerRadius="6" Padding="12,5" Cursor="Hand" PointerPressed="TrackShowWeek">
                                        <TextBlock Text="Week" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel x:Name="TrackDayPanel">
                                    <ItemsControl x:Name="TrackPrayerList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:DeedEntry">
                                                <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="{Binding Label}" Foreground="White" FontSize="12"/>
                                                        <Border Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#AFFFFFFF" BorderThickness="1.5" Cursor="Hand" PointerPressed="ToggleTrackItem">
                                                            <Border.Styles>
                                                                <Style Selector="Border.checked">
                                                                    <Setter Property="Background" Value="#10B981"/>
                                                                    <Setter Property="BorderBrush" Value="#10B981"/>
                                                                </Style>
                                                            </Border.Styles>
                                                            <TextBlock Text="✓" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsChecked}"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <StackPanel x:Name="TrackWeekPanel" IsVisible="False">
                                    <TextBlock x:Name="WeekSummaryText" Text="Loading..." Foreground="White" FontSize="12" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Classes="card" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="Fasting (Sawm)" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                <Border Background="#1AFFFFFF" CornerRadius="6" Padding="10,8" Margin="0,6,0,0" Cursor="Hand" PointerPressed="ToggleSawm">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border x:Name="SawmCheck" Width="18" Height="18" CornerRadius="3" BorderBrush="#AFFFFFFF" BorderThickness="1.5"/>
                                        <TextBlock x:Name="SawmLabel" Grid.Column="1" Text="Mark today as fasting" Foreground="White" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- DUAS -->
            <TabItem Header="📖 Duas">
                <ScrollViewer>
                    <StackPanel Margin="12">
                        <TextBlock Text="📖 Duas &amp; Supplications" Classes="section-title"/>
                        <ItemsControl x:Name="DuasList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:DuaCardItem">
                                    <Border Classes="card" Margin="0,0,0,6" Padding="0" Cursor="Hand" PointerPressed="ToggleDuaCard">
                                        <StackPanel>
                                            <Grid Margin="12,10,12,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Foreground="#FBBF24" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Arrow}" Foreground="White" Opacity="0.5" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                            <Border Background="#0A111111" Margin="12,0,12,10" IsVisible="{Binding ContentVisible}">
                                                <StackPanel>
                                                    <Border Background="#15111111" CornerRadius="6" Padding="10,8">
                                                        <TextBlock Text="{Binding Arabic}" Foreground="White" FontSize="14" FontFamily="Traditional Arabic, Segoe UI" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Transliteration}" Foreground="White" Opacity="0.7" FontSize="10" FontStyle="Italic" TextWrapping="Wrap" Margin="0,6,0,3"/>
                                                    <TextBlock Text="{Binding Translation}" Foreground="White" Opacity="0.5" FontSize="10" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Reference}" Foreground="#9CA3AF" Opacity="0.4" FontSize="8" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ABOUT -->
            <TabItem Header="ℹ About">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12" Spacing="8">
                    <TextBlock Text="Daily Prayer Timer" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Cross-Platform Build" FontSize="12" Foreground="#10B981" HorizontalAlignment="Center"/>
                    <Border Classes="card" Width="300">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Avalonia UI + .NET 8" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="• Prayer times with AlAdhan API" FontSize="11" Foreground="#9CA3AF"/>
                            <TextBlock Text="• Qibla direction finder" FontSize="11" Foreground="#9CA3AF"/>
                            <TextBlock Text="• Digital Tasbih counter" FontSize="11" Foreground="#9CA3AF"/>
                            <TextBlock Text="• 27 after-salaam duas" FontSize="11" Foreground="#9CA3AF"/>
                            <TextBlock Text="• Ramadan tracker" FontSize="11" Foreground="#9CA3AF"/>
                            <TextBlock Text="• Daily deed tracking" FontSize="11" Foreground="#9CA3AF"/>
                            <TextBlock Text="• Linux notifications" FontSize="11" Foreground="#9CA3AF"/>
                            <TextBlock Text="• Hijri calendar" FontSize="11" Foreground="#9CA3AF"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="github.com/AbiruzzamanMolla" FontSize="10" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                </StackPanel>
            </TabItem>

            <!-- SETTINGS -->
            <TabItem Header="⚙ Settings">
                <ScrollViewer>
                    <StackPanel Margin="12" Spacing="8">
                        <TextBlock Text="Location &amp; Calculation" Classes="section-title"/>
                        <Border Classes="card">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Latitude" FontSize="10" Foreground="#9CA3AF"/>
                                <TextBox x:Name="LatInput" Text="{Binding Latitude}" Watermark="23.8103" Foreground="White" Background="#1AFFFFFF"/>
                                <TextBlock Text="Longitude" FontSize="10" Foreground="#9CA3AF"/>
                                <TextBox x:Name="LonInput" Text="{Binding Longitude}" Watermark="90.4125" Foreground="White" Background="#1AFFFFFF"/>
                                <TextBlock Text="Calculation Method" FontSize="10" Foreground="#9CA3AF"/>
                                <ComboBox x:Name="MethodInput" SelectedIndex="{Binding MethodIndex}" Foreground="White" Background="#1AFFFFFF">
                                    <ComboBoxItem Content="Karachi" Tag="KARACHI"/>
                                    <ComboBoxItem Content="MWL" Tag="MWL" IsSelected="True"/>
                                    <ComboBoxItem Content="Makkah" Tag="MAKKAH"/>
                                    <ComboBoxItem Content="ISNA" Tag="ISNA"/>
                                    <ComboBoxItem Content="Egypt" Tag="EGYPT"/>
                                </ComboBox>
                                <Border Background="#10B981" CornerRadius="6" Padding="12,8" Cursor="Hand" PointerPressed="ApplySettings" HorizontalAlignment="Right">
                                    <TextBlock Text="Apply" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Notifications" Classes="section-title"/>
                        <Border Classes="card">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Prayer notifications via system" FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                                    <Border x:Name="NotifyToggle" Width="40" Height="22" CornerRadius="11" Background="#2AFFFFFF" Cursor="Hand" PointerPressed="ToggleNotify">
                                        <Ellipse x:Name="NotifyKnob" Width="16" Height="16" Fill="#9CA3AF" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="About" Classes="section-title"/>
                        <Border Classes="card">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Daily Prayer Timer" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Avalonia Cross-Platform Build" FontSize="10" Foreground="#10B981"/>
                                <TextBlock Text=".NET 8 + Avalonia UI 12.0" FontSize="10" Foreground="#9CA3AF"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#00170939" Padding="0" Height="0"/>
    </Grid>
</Window>
