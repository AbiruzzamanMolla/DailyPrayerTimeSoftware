<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:DailyPrayerTime.Desktop"
             x:Class="DailyPrayerTime.Desktop.App"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://DailyPrayerTime.Desktop/Styles/Theme.axaml" />
    </Application.Styles>
</Application>
